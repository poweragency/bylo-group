---
const currentLocale = (Astro.currentLocale ?? 'it') as 'it' | 'en';
const label = currentLocale === 'en' ? 'Back to top' : 'Torna in cima';
---

<button
  id="bylo-back-to-top"
  type="button"
  aria-label={label}
  title={label}
  class="fixed bottom-5 right-5 sm:bottom-7 sm:right-7 z-50 w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-byl-black text-byl-yellow shadow-[0_8px_24px_rgba(0,0,0,0.25)] hover:shadow-[0_12px_32px_rgba(0,0,0,0.35)] hover:bg-byl-graphite hover:-translate-y-0.5 active:scale-95 transition-all duration-300 opacity-0 translate-y-4 pointer-events-none flex items-center justify-center group"
  style="padding-bottom: env(safe-area-inset-bottom);"
  hidden
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="22"
    height="22"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="transition-transform group-hover:-translate-y-0.5"
    aria-hidden="true"
  >
    <line x1="12" y1="19" x2="12" y2="5"></line>
    <polyline points="5 12 12 5 19 12"></polyline>
  </svg>
</button>

<script is:inline>
  (() => {
    const btn = document.getElementById('bylo-back-to-top');
    if (!btn) return;
    const SHOW_AFTER = 400;
    let visible = false;
    let hideTimer = 0;

    function update() {
      const shouldShow = window.scrollY > SHOW_AFTER;
      if (shouldShow === visible) return;
      visible = shouldShow;
      if (shouldShow) {
        clearTimeout(hideTimer);
        btn.hidden = false;
        requestAnimationFrame(() => {
          btn.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
        });
      } else {
        btn.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
        hideTimer = window.setTimeout(() => {
          if (!visible) btn.hidden = true;
        }, 300);
      }
    }

    window.addEventListener('scroll', update, { passive: true });
    btn.addEventListener('click', () => {
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollTo({ top: 0, behavior: reduced ? 'auto' : 'smooth' });
      btn.blur();
    });
    update();
  })();
</script>
