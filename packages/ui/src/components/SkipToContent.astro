---
interface Props {
  href?: string;
  locale?: 'it' | 'en';
}

const { href = '#main', locale = 'it' } = Astro.props;
const label = locale === 'en' ? 'Skip to main content' : 'Vai al contenuto principale';
---

<a
  href={href}
  class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-byl-yellow focus:text-byl-black focus:font-semibold focus:rounded-md focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-byl-black"
>
  {label}
</a>
