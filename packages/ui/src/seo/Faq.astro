---
import SchemaOrg from './SchemaOrg.astro';

export interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  items: FaqItem[];
  title?: string;
  eyebrow?: string;
  inverse?: boolean;
}

const { items, title = 'Domande frequenti', eyebrow, inverse = false } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<section class:list={['section-pad', inverse ? 'bg-byl-black text-byl-white' : 'bg-byl-white text-byl-black']}>
  <div class="container-page">
    <div class="max-w-3xl">
      {eyebrow && (
        <span class:list={[inverse ? 'eyebrow-on-dark' : 'eyebrow']}>{eyebrow}</span>
      )}
      <h2 class:list={['h-section mt-4', inverse && 'text-byl-white']}>{title}</h2>
    </div>

    <div class="mt-12 max-w-3xl divide-y divide-current/10">
      {items.map((item) => (
        <details class="group py-6">
          <summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
            <h3 class="text-lg font-semibold leading-snug">{item.q}</h3>
            <span
              class="flex-shrink-0 w-6 h-6 rounded-full border border-current/30 flex items-center justify-center transition-transform group-open:rotate-45"
              aria-hidden="true"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
            </span>
          </summary>
          <div class="mt-4 text-current/70 leading-relaxed" set:html={item.a} />
        </details>
      ))}
    </div>
  </div>
</section>

<SchemaOrg data={schema} />
