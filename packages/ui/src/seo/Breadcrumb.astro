---
import SchemaOrg from './SchemaOrg.astro';

export interface Crumb {
  label: string;
  href: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    item: new URL(c.href, Astro.site).toString(),
  })),
};
---

<nav aria-label="Breadcrumb" class="container-page py-4 text-sm text-byl-mute">
  <ol class="flex flex-wrap items-center gap-2">
    {items.map((c, i) => (
      <li class="flex items-center gap-2">
        {i < items.length - 1 ? (
          <a href={c.href} class="hover:text-byl-black transition-colors">
            {c.label}
          </a>
        ) : (
          <span aria-current="page" class="text-byl-black font-medium">{c.label}</span>
        )}
        {i < items.length - 1 && (
          <span class="text-byl-mute/50" aria-hidden="true">/</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<SchemaOrg data={schema} />
