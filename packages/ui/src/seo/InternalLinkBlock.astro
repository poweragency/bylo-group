---
export interface InternalLink {
  href: string;
  label: string;
  description?: string;
  external?: boolean;
}

interface Props {
  title: string;
  eyebrow?: string;
  links: InternalLink[];
  columns?: 2 | 3;
}

const { title, eyebrow, links, columns = 3 } = Astro.props;
const gridCols = columns === 2 ? 'md:grid-cols-2' : 'md:grid-cols-3';
---

<section class="section-pad bg-byl-off">
  <div class="container-page">
    <div class="max-w-3xl">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2 class="h-section mt-4">{title}</h2>
    </div>

    <div class:list={['mt-12 grid grid-cols-1 gap-5', gridCols]}>
      {links.map((link) => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          class="group block p-7 rounded-xl bg-byl-white border border-byl-stone hover:border-byl-black hover:shadow-[var(--shadow-hover)] transition-all"
        >
          <div class="flex items-start justify-between gap-3">
            <span class="font-semibold text-byl-black leading-snug">{link.label}</span>
            <svg
              class="flex-shrink-0 mt-1 text-byl-mute group-hover:text-byl-black group-hover:translate-x-0.5 transition-all"
              xmlns="http://www.w3.org/2000/svg"
              width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </div>
          {link.description && (
            <p class="mt-3 text-sm text-byl-mute leading-relaxed">{link.description}</p>
          )}
        </a>
      ))}
    </div>
  </div>
</section>
