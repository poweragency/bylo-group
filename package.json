{
  "name": "bylo-monorepo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:logistica": "npm run dev -w apps/bylo-logistica",
    "build:logistica": "npm run build -w apps/bylo-logistica",
    "preview:logistica": "npm run preview -w apps/bylo-logistica",
    "dev:racing": "npm run dev -w apps/bylo-racing",
    "build:racing": "npm run build -w apps/bylo-racing",
    "preview:racing": "npm run preview -w apps/bylo-racing",
    "dev:group": "npm run dev -w apps/bylo-group",
    "build:group": "npm run build -w apps/bylo-group",
    "preview:group": "npm run preview -w apps/bylo-group",
    "build:all": "npm run build:group && npm run build:logistica && npm run build:racing",
    "deploy:group": "vercel link --project=bylo-group --yes && vercel deploy --prod --yes --local-config=vercel-group.json",
    "deploy:transport": "vercel link --project=bylo-transport --yes && vercel deploy --prod --yes --local-config=vercel-logistica.json",
    "deploy:tommy": "vercel link --project=bylo-tommy --yes && vercel deploy --prod --yes --local-config=vercel-racing.json"
  }
}
