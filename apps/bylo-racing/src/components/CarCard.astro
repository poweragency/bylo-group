---
import type { Car } from '@/lib/cars';
import { formatPrice, formatKm, formatFuel } from '@/lib/cars';

interface Props {
  car: Car;
  priority?: boolean;
}

const { car, priority = false } = Astro.props;
---

<a
  href={`/auto/${car.slug}/`}
  class="group block bg-white border border-byl-stone rounded-xl overflow-hidden hover:border-byl-black hover:shadow-[var(--shadow-hover)] transition-all"
>
  <div class="relative aspect-[4/3] overflow-hidden bg-byl-stone">
    <img
      src={car.image}
      alt={`${car.brand} ${car.model} ${car.version ?? ''}`}
      class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
    />
    <div class="absolute top-3 left-3 bg-byl-yellow text-byl-black px-2.5 py-1 text-xs font-bold uppercase tracking-wider rounded-sm">
      {formatFuel(car.fuel)}
    </div>
  </div>

  <div class="p-5">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <div class="text-xs uppercase tracking-wider text-byl-mute">{car.brand}</div>
        <h3 class="font-display font-semibold text-lg leading-tight mt-0.5 truncate">
          {car.model}
        </h3>
        {car.version && (
          <div class="text-sm text-byl-mute truncate mt-0.5">{car.version}</div>
        )}
      </div>
      <div class="text-right flex-shrink-0">
        <div class="font-display font-bold text-xl text-byl-black">{formatPrice(car.price)}</div>
      </div>
    </div>

    <div class="mt-4 pt-4 border-t border-byl-stone grid grid-cols-3 gap-2 text-xs">
      <div>
        <div class="text-byl-mute uppercase tracking-wider">Anno</div>
        <div class="mt-0.5 font-semibold text-byl-black">{car.year}</div>
      </div>
      <div>
        <div class="text-byl-mute uppercase tracking-wider">Km</div>
        <div class="mt-0.5 font-semibold text-byl-black">{formatKm(car.km)}</div>
      </div>
      <div>
        <div class="text-byl-mute uppercase tracking-wider">Potenza</div>
        <div class="mt-0.5 font-semibold text-byl-black">{car.power_cv} CV</div>
      </div>
    </div>
  </div>
</a>
