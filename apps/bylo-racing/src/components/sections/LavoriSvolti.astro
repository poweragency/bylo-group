---
import BeforeAfter from '@/components/BeforeAfter.astro';

const lavori = [
  {
    title: 'Personalizzazione racing',
    subtitle: 'Volkswagen Golf · Linee racing su cofano e tetto',
    description:
      "Posa di linee racing in carbonio su cofano e tetto, con applicazione manuale millimetrica per un risultato pulito e duraturo.",
    before: '/photos/lavoro1-prima',
    after: '/photos/lavoro1-dopo',
  },
  {
    title: 'Wrapping integrale',
    subtitle: 'Golf 7 lucida → Golf 8 GTI nera opaca',
    description:
      "Trasformazione completa con wrapping nero opaco, particolari neri lucidi e finitura GTI. Cambio radicale dell'estetica senza intervenire sulla vernice originale.",
    before: '/photos/lavoro2-prima',
    after: '/photos/lavoro2-dopo',
  },
];
---

<section id="lavori-svolti" class="section-pad bg-byl-off">
  <div class="container-page">
    <div class="max-w-3xl">
      <span class="eyebrow">Lavori svolti</span>
      <h2 class="h-section mt-4">
        Il <span class="text-byl-yellow-dark">prima e dopo</span> dei nostri interventi.
      </h2>
      <p class="lede mt-6">
        Ogni auto che passa nei nostri spazi ha una storia da raccontare.
        Trascina lo slider per vedere com'era quando è arrivata e com'è
        uscita dopo l'intervento dei nostri tecnici.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 lg:grid-cols-2 gap-8">
      {
        lavori.map((l) => (
          <article class="bg-white rounded-2xl border border-byl-stone overflow-hidden hover:shadow-[var(--shadow-hover)] transition-shadow">
            <BeforeAfter
              before={l.before}
              after={l.after}
              alt={l.title}
            />
            <div class="p-6 md:p-8">
              <span class="eyebrow text-xs">{l.subtitle}</span>
              <h3 class="h-card mt-2">{l.title}</h3>
              <p class="mt-3 text-byl-mute leading-relaxed text-sm">
                {l.description}
              </p>
            </div>
          </article>
        ))
      }
    </div>

    <p class="mt-10 text-center text-byl-mute text-sm">
      Hai un progetto in mente?
      <a href="#contatti" class="text-byl-black font-semibold underline underline-offset-4 hover:text-byl-yellow-dark">
        Raccontacelo
      </a>, ti diciamo come lo realizzeremmo.
    </p>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-ba]').forEach((root) => {
    const before = root.querySelector<HTMLElement>('.ba-before');
    const line = root.querySelector<HTMLElement>('.ba-line');
    const handle = root.querySelector<HTMLElement>('.ba-handle');
    const range = root.querySelector<HTMLInputElement>('.ba-range');
    if (!before || !line || !handle || !range) return;

    let dragging = false;

    const setPos = (pct: number) => {
      const p = Math.max(0, Math.min(100, pct));
      before.style.clipPath = `inset(0 ${100 - p}% 0 0)`;
      line.style.left = `${p}%`;
      handle.style.left = `${p}%`;
      range.value = String(Math.round(p));
    };

    const fromEvent = (e: PointerEvent | MouseEvent | TouchEvent) => {
      const rect = root.getBoundingClientRect();
      let clientX: number;
      if ('touches' in e && e.touches.length) {
        clientX = e.touches[0].clientX;
      } else if ('clientX' in e) {
        clientX = e.clientX;
      } else {
        return;
      }
      const x = clientX - rect.left;
      setPos((x / rect.width) * 100);
    };

    const start = (e: PointerEvent) => {
      dragging = true;
      handle.setPointerCapture?.(e.pointerId);
      fromEvent(e);
    };
    const move = (e: PointerEvent) => {
      if (!dragging) return;
      e.preventDefault();
      fromEvent(e);
    };
    const end = (e: PointerEvent) => {
      dragging = false;
      handle.releasePointerCapture?.(e.pointerId);
    };

    handle.addEventListener('pointerdown', start);
    handle.addEventListener('pointermove', move);
    handle.addEventListener('pointerup', end);
    handle.addEventListener('pointercancel', end);

    // Click on container also moves the slider
    root.addEventListener('click', (e) => {
      if (e.target === handle || handle.contains(e.target as Node)) return;
      fromEvent(e);
    });

    // Keyboard support via range
    range.addEventListener('input', () => setPos(Number(range.value)));

    // Auto demo: slow nudge on first viewport entry, then stop
    const io = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) return;
        io.disconnect();
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        let v = 50;
        let dir = 1;
        let frames = 0;
        const id = setInterval(() => {
          v += dir * 1.2;
          if (v > 70) dir = -1;
          if (v < 30) dir = 1;
          setPos(v);
          frames++;
          if (frames > 80) {
            clearInterval(id);
            setPos(50);
          }
        }, 30);
      },
      { threshold: 0.3 }
    );
    io.observe(root);
  });
</script>
