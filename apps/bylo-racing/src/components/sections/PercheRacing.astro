---
const benefits = [
  {
    title: 'Officina autorizzata',
    body: 'Autorizzati per revisioni ministeriali su veicoli fino a 35 quintali. Pratica gestita internamente.',
  },
  {
    title: 'Tecnici multimarca',
    body: 'Esperienza su tutte le principali case automobilistiche. Garanzia del costruttore sempre preservata.',
  },
  {
    title: 'Carrozzeria completa',
    body: 'Cabina di verniciatura dedicata, tintometro, area preparazione. Vernici ad acqua a basso impatto ambientale.',
  },
  {
    title: 'Un interlocutore solo',
    body: 'Meccanica, carrozzeria e vendita sotto lo stesso tetto. Meno passaggi, più semplicità per te.',
  },
];
---

<section id="perche" class="section-pad bg-byl-white">
  <div class="container-page">
    <div class="max-w-3xl">
      <span class="eyebrow">Perché Tommy Racing</span>
      <h2 class="h-section mt-4">
        Quattro buone ragioni per <span class="text-byl-yellow-dark">fidarti</span>.
      </h2>
    </div>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      {
        benefits.map((b, i) => (
          <div class="group relative p-7 rounded-xl bg-byl-off border border-byl-stone hover:border-byl-black hover:bg-white hover:shadow-[var(--shadow-hover)] transition-all overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-[2px] bg-byl-yellow transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300" />
            <div class="text-byl-yellow-dark font-display font-bold text-sm tracking-widest">
              0{i + 1}
            </div>
            <h3 class="h-card mt-4">{b.title}</h3>
            <p class="mt-3 text-byl-mute leading-relaxed text-sm">{b.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
