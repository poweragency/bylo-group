---
import { CONTACTS_RACING } from '@bylo/ui/index.ts';

const { officina, carrozzeria } = CONTACTS_RACING;
const services = ['Officina multimarca', 'Carrozzeria', 'Verniciatura', 'Tintometro'];
---

<section id="sedi" class="section-pad bg-byl-off">
  <div class="container-page">
    <div class="max-w-3xl">
      <span class="eyebrow">La nostra sede</span>
      <h2 class="h-section mt-4">
        Officina, carrozzeria & <span class="text-byl-yellow-dark">verniciatura</span>.
      </h2>
      <p class="lede mt-6">
        Una sede unica a Mazzo di Rho (alle porte di Milano) con officina
        multimarca per auto e moto e carrozzeria attrezzata con cabina
        professionale, tintometro e forno ad acqua per finiture di qualità.
      </p>
    </div>

    <div class="mt-14 max-w-3xl">
      <div class="group relative p-8 md:p-10 bg-white border border-byl-stone rounded-2xl hover:border-byl-black hover:shadow-[var(--shadow-hover)] transition-all overflow-hidden">
        <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-byl-yellow/10 blur-3xl group-hover:bg-byl-yellow/20 transition-colors" />

        <div class="relative">
          <span class="eyebrow">Sede {officina.city}</span>
          <h3 class="h-card mt-3">Tommy By</h3>

          <div class="mt-6 flex flex-wrap gap-2">
            {services.map((s) => (
              <span class="inline-flex items-center bg-byl-off text-byl-black px-3 py-1 rounded-full text-xs font-medium border border-byl-stone">
                {s}
              </span>
            ))}
          </div>

          <div class="mt-8 pt-6 border-t border-byl-stone space-y-3 text-sm">
            <div class="flex items-start gap-3">
              <svg class="flex-shrink-0 mt-0.5 text-byl-yellow-dark" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              <span class="text-byl-black">{officina.address}</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="flex-shrink-0 mt-0.5 text-byl-yellow-dark" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              <a href={`tel:${officina.phone.replace(/\s/g, '')}`} class="text-byl-black font-medium hover:text-byl-yellow-dark">
                {officina.phone}
              </a>
            </div>
            <div class="flex items-start gap-3">
              <svg class="flex-shrink-0 mt-0.5 text-byl-yellow-dark" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              <span class="text-byl-mute">{officina.hours}</span>
            </div>
          </div>

          <div class="mt-6 pt-6 border-t border-byl-stone grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <div class="text-xs uppercase tracking-wider text-byl-mute">Officina · Ref. {officina.referent}</div>
              <a href={`mailto:${officina.email}`} class="mt-1 inline-block text-sm font-medium text-byl-black hover:text-byl-yellow-dark break-all">
                {officina.email}
              </a>
            </div>
            <div>
              <div class="text-xs uppercase tracking-wider text-byl-mute">Carrozzeria · Ref. {carrozzeria.referent}</div>
              <a href={`mailto:${carrozzeria.email}`} class="mt-1 inline-block text-sm font-medium text-byl-black hover:text-byl-yellow-dark break-all">
                {carrozzeria.email}
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
