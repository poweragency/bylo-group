---
import { CONTACTS_RACING, BRAND_RACING } from '@bylo/ui/index.ts';

const tipi = [
  'Tagliando / manutenzione',
  'Revisione ministeriale',
  'Preventivo carrozzeria',
  'Informazioni su un\'auto',
  'Altro',
];

const { officina, carrozzeria } = CONTACTS_RACING;
// WhatsApp: rimuoviamo spazi/+ per costruire link wa.me
const waNum = officina.phone.replace(/[^\d]/g, '');

const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
const isConfigured = accessKey.length > 0;
const subject = `Nuova richiesta da ${BRAND_RACING.name}`;
---

<section id="contatti" class="section-pad bg-byl-white">
  <div class="container-page">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <span class="eyebrow">Parliamone</span>
        <h2 class="h-section mt-4">
          Raccontaci cosa ti serve, <span class="text-byl-yellow-dark">ti ricontattiamo</span>.
        </h2>
        <p class="lede mt-6">
          Compila il modulo oppure scrivici su WhatsApp. Ti rispondiamo
          il prima possibile con una proposta concreta.
        </p>

        <div class="mt-10 space-y-4">
          <a
            href={`https://wa.me/${waNum}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-5 bg-byl-off border border-byl-stone rounded-xl hover:border-byl-black hover:bg-white transition-all group"
          >
            <div class="w-12 h-12 rounded-lg bg-[#25D366] flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>
            <div>
              <div class="font-semibold text-byl-black">Scrivici su WhatsApp</div>
              <div class="text-sm text-byl-mute">Risposta rapida negli orari d'ufficio</div>
            </div>
          </a>

          <a
            href={`tel:${officina.phone.replace(/\s/g, '')}`}
            class="flex flex-col p-5 bg-byl-off border border-byl-stone rounded-lg hover:border-byl-black transition-colors"
          >
            <span class="text-xs uppercase tracking-wider text-byl-mute">Officina &amp; Carrozzeria</span>
            <span class="mt-1 font-semibold text-byl-black text-base">{officina.phone}</span>
          </a>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <a
              href={`mailto:${officina.email}`}
              class="flex flex-col p-4 bg-byl-off border border-byl-stone rounded-lg hover:border-byl-black transition-colors"
            >
              <span class="text-xs uppercase tracking-wider text-byl-mute">Officina · Ref. {officina.referent}</span>
              <span class="mt-1 font-medium text-byl-black text-sm break-all">{officina.email}</span>
            </a>
            <a
              href={`mailto:${carrozzeria.email}`}
              class="flex flex-col p-4 bg-byl-off border border-byl-stone rounded-lg hover:border-byl-black transition-colors"
            >
              <span class="text-xs uppercase tracking-wider text-byl-mute">Carrozzeria · Ref. {carrozzeria.referent}</span>
              <span class="mt-1 font-medium text-byl-black text-sm break-all">{carrozzeria.email}</span>
            </a>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7">
        <form
          id="contact-form-racing"
          data-bylo-form
          class="bg-byl-off p-8 md:p-10 rounded-2xl border border-byl-stone"
          method="POST"
          action="https://api.web3forms.com/submit"
          novalidate
        >
          <input type="hidden" name="access_key" value={accessKey} />
          <input type="hidden" name="subject" value={subject} />
          <input type="hidden" name="from_name" value={BRAND_RACING.name} />
          <input type="hidden" name="redirect" value="/grazie" />
          <input
            type="checkbox"
            name="botcheck"
            class="hidden"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label for="nome" class="text-sm font-medium text-byl-black">Nome e cognome *</label>
              <input id="nome" name="nome" type="text" required autocomplete="name" autocapitalize="words" enterkeyhint="next" class="mt-2 w-full px-4 py-3 text-base bg-white border border-byl-stone rounded-md focus:outline-none focus:border-byl-black focus:ring-2 focus:ring-byl-yellow/40 transition-all" />
            </div>
            <div>
              <label for="telefono" class="text-sm font-medium text-byl-black">Telefono *</label>
              <input id="telefono" name="telefono" type="tel" required autocomplete="tel" inputmode="tel" enterkeyhint="next" class="mt-2 w-full px-4 py-3 text-base bg-white border border-byl-stone rounded-md focus:outline-none focus:border-byl-black focus:ring-2 focus:ring-byl-yellow/40 transition-all" />
            </div>
            <div class="md:col-span-2">
              <label for="email" class="text-sm font-medium text-byl-black">Email</label>
              <input id="email" name="email" type="email" autocomplete="email" inputmode="email" autocapitalize="off" spellcheck="false" enterkeyhint="next" class="mt-2 w-full px-4 py-3 text-base bg-white border border-byl-stone rounded-md focus:outline-none focus:border-byl-black focus:ring-2 focus:ring-byl-yellow/40 transition-all" />
            </div>
            <div class="md:col-span-2">
              <label for="auto" class="text-sm font-medium text-byl-black">Marca / modello auto</label>
              <input id="auto" name="auto" type="text" autocomplete="off" autocapitalize="words" enterkeyhint="next" placeholder="Es. Fiat 500, VW Golf 2018…" class="mt-2 w-full px-4 py-3 text-base bg-white border border-byl-stone rounded-md focus:outline-none focus:border-byl-black focus:ring-2 focus:ring-byl-yellow/40 transition-all" />
            </div>
          </div>

          <div class="mt-5">
            <label class="text-sm font-medium text-byl-black">Di cosa hai bisogno?</label>
            <div class="mt-3 flex flex-wrap gap-2">
              {
                tipi.map((t) => (
                  <label class="group inline-flex items-center gap-2 px-4 py-2 bg-white border border-byl-stone rounded-full cursor-pointer hover:border-byl-black has-[:checked]:bg-byl-black has-[:checked]:text-byl-yellow has-[:checked]:border-byl-black transition-all">
                    <input type="checkbox" name="tipo" value={t} class="sr-only" />
                    <span class="text-sm font-medium">{t}</span>
                  </label>
                ))
              }
            </div>
          </div>

          <div class="mt-5">
            <label for="messaggio" class="text-sm font-medium text-byl-black">Dettagli *</label>
            <textarea id="messaggio" name="messaggio" rows="5" required enterkeyhint="enter" autocapitalize="sentences" placeholder="Cosa ti serve, quando, eventuali riferimenti…" class="mt-2 w-full px-4 py-3 text-base bg-white border border-byl-stone rounded-md focus:outline-none focus:border-byl-black focus:ring-2 focus:ring-byl-yellow/40 transition-all resize-none"></textarea>
          </div>

          <label class="mt-5 flex items-start gap-3 text-sm text-byl-mute cursor-pointer">
            <input type="checkbox" name="privacy" required class="mt-1 accent-byl-black" />
            <span>Ho letto e accetto la <a href="/privacy" class="underline hover:text-byl-black">Privacy Policy</a> e acconsento al trattamento dei dati.</span>
          </label>

          <button type="submit" class="btn-primary mt-8 w-full md:w-auto" data-form-submit>
            <span data-label-idle>Invia richiesta</span>
            <span data-label-loading class="hidden">Invio in corso…</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </button>

          <div data-form-feedback aria-live="polite" class="mt-4 text-sm hidden"></div>

          {!isConfigured && (
            <p class="mt-4 text-xs text-byl-mute italic">
              ⚠ Form non ancora attivato. Per ora puoi scriverci a {officina.email} o {carrozzeria.email}, oppure su WhatsApp.
            </p>
          )}
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector('#contact-form-racing') as HTMLFormElement | null;
  if (form) {
    const feedback = form.querySelector('[data-form-feedback]') as HTMLElement;
    const submit = form.querySelector('[data-form-submit]') as HTMLButtonElement;
    const labelIdle = submit?.querySelector('[data-label-idle]');
    const labelLoading = submit?.querySelector('[data-label-loading]');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      if (data.get('botcheck')) return;
      if (!data.get('privacy')) {
        feedback.textContent = 'Devi accettare la Privacy Policy per inviare la richiesta.';
        feedback.className = 'mt-4 text-sm text-red-600';
        feedback.classList.remove('hidden');
        return;
      }

      submit.disabled = true;
      labelIdle?.classList.add('hidden');
      labelLoading?.classList.remove('hidden');
      feedback.classList.add('hidden');

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        const json = await res.json();
        if (json.success) {
          form.reset();
          feedback.innerHTML = `<strong class="text-byl-black">Grazie!</strong> Abbiamo ricevuto la tua richiesta — ti ricontattiamo il prima possibile.`;
          feedback.className = 'mt-4 p-4 bg-byl-yellow/15 border border-byl-yellow rounded-md text-sm text-byl-black';
          feedback.classList.remove('hidden');
        } else {
          throw new Error(json.message || 'Submit failed');
        }
      } catch (err) {
        feedback.innerHTML = `Errore nell'invio. Riprova oppure scrivici su WhatsApp.`;
        feedback.className = 'mt-4 text-sm text-red-600';
        feedback.classList.remove('hidden');
      } finally {
        submit.disabled = false;
        labelIdle?.classList.remove('hidden');
        labelLoading?.classList.add('hidden');
      }
    });
  }
</script>
