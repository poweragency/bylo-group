---
import { CONTACTS_RACING } from '@bylo/ui/index.ts';

const sedi = [CONTACTS_RACING.carrozzeria];

function mapsEmbed(address: string) {
  return `https://maps.google.com/maps?q=${encodeURIComponent(address)}&z=15&output=embed`;
}

function directionsLink(address: string) {
  return `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(address)}`;
}
---

<section id="dove-siamo" class="section-pad bg-byl-white">
  <div class="container-page">
    <div class="max-w-3xl">
      <span class="eyebrow">Dove siamo</span>
      <h2 class="h-section mt-4">
        A pochi minuti dalle <span class="text-byl-yellow-dark">tangenziali di Milano</span>.
      </h2>
    </div>

    <div class="mt-14 max-w-2xl">
      {
        sedi.map((sede) => (
          <div class="bg-byl-off rounded-2xl border border-byl-stone overflow-hidden flex flex-col">
            <div class="relative h-[340px]">
              <iframe
                src={mapsEmbed(sede.address)}
                title={`Mappa ${sede.label}`}
                class="absolute inset-0 w-full h-full"
                style="border: 0;"
                loading="lazy"
                allowfullscreen
                referrerpolicy="no-referrer-when-downgrade"
              />
            </div>
            <div class="p-6 md:p-7 flex-1 flex flex-col">
              <span class="eyebrow">{sede.city}</span>
              <h3 class="h-card mt-2">{sede.label}</h3>
              <p class="mt-3 text-byl-mute text-sm leading-relaxed">{sede.address}</p>
              <a
                href={directionsLink(sede.address)}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-outline mt-6 self-start text-sm"
              >
                Indicazioni stradali
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"></polygon></svg>
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
