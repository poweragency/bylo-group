---
const steps = [
  {
    title: 'Diagnosi del danno',
    body: 'Analisi completa del veicolo e preventivo trasparente, con foto e dettaglio lavorazioni.',
  },
  {
    title: 'Preparazione & riparazione',
    body: 'Lavorazioni carrozzeria, sostituzione parti, raddrizzatura scocca, stuccatura e carteggiatura.',
  },
  {
    title: 'Tintometro',
    body: 'Abbinamento tinta preciso con tintometro professionale. La tua vernice, identica all\'originale.',
  },
  {
    title: 'Verniciatura a forno',
    body: 'Cabina dedicata, vernici ad acqua a basso impatto ambientale, asciugatura controllata a forno.',
  },
];
---

<section id="carrozzeria" class="section-pad bg-byl-black text-byl-white relative overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.04] pointer-events-none"
    style="background-image: linear-gradient(to right, #fff 1px, transparent 1px), linear-gradient(to bottom, #fff 1px, transparent 1px); background-size: 80px 80px;"
  >
  </div>

  <div class="container-page relative">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <div class="lg:col-span-5">
        <span class="eyebrow-on-dark">Carrozzeria & verniciatura</span>
        <h2 class="h-section mt-4 text-byl-white">
          Finitura a regola d'arte, <span class="text-byl-yellow">rispettosa dell'ambiente</span>.
        </h2>
        <p class="lede mt-6 text-white/70">
          La nostra cabina di verniciatura utilizza esclusivamente
          <strong class="text-byl-white">vernici ad acqua</strong> —
          una scelta che riduce l'impatto ambientale senza compromettere
          la qualità della finitura. Dal piccolo ritocco al ripristino
          completo dopo un sinistro, ogni intervento passa attraverso
          un processo controllato e documentato.
        </p>

        <div class="mt-10 space-y-5">
          {
            steps.map((s, i) => (
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-byl-yellow text-byl-black flex items-center justify-center font-display font-bold text-sm">
                  {String(i + 1).padStart(2, '0')}
                </div>
                <div>
                  <h3 class="font-display font-semibold text-lg text-byl-white">{s.title}</h3>
                  <p class="mt-1 text-white/60 text-sm leading-relaxed">{s.body}</p>
                </div>
              </div>
            ))
          }
        </div>

        <a href="#contatti" class="btn-primary mt-10">
          Richiedi un preventivo carrozzeria
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>

      <div class="lg:col-span-7">
        <div class="relative aspect-[4/5] rounded-2xl overflow-hidden bg-byl-graphite border border-white/10">
          <picture>
            <source srcset="/photos/carrozzeria-forno.avif" type="image/avif" />
            <source srcset="/photos/carrozzeria-forno.webp" type="image/webp" />
            <img
              src="/photos/carrozzeria-forno.jpg"
              alt="Cabina di verniciatura, tintometro e area preparazione nella carrozzeria Tommy By"
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </picture>
          <div class="absolute inset-0 bg-gradient-to-t from-byl-black/50 via-transparent to-transparent"></div>

          <div class="absolute bottom-6 left-6 right-6 flex flex-wrap gap-2">
            <span class="bg-byl-yellow text-byl-black px-3 py-1.5 text-xs font-bold uppercase tracking-wider rounded-sm">
              Verniciatura
            </span>
            <span class="bg-byl-white text-byl-black px-3 py-1.5 text-xs font-bold uppercase tracking-wider rounded-sm">
              Tintometro
            </span>
            <span class="bg-byl-white/20 backdrop-blur text-byl-white border border-white/30 px-3 py-1.5 text-xs font-bold uppercase tracking-wider rounded-sm">
              Preparazione
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
