---
const slides = [
  { base: 'hero-car-1', alt: 'Auto di prestigio, supersportiva bianca in esposizione' },
  { base: 'hero-car-2', alt: 'Berlina sportiva tedesca, cerchi diamantati' },
  { base: 'hero-car-3', alt: 'Coupé premium nera, vista posteriore' },
];
---

<section class="relative bg-byl-black text-byl-white overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.04] pointer-events-none"
    style="background-image: linear-gradient(to right, #fff 1px, transparent 1px), linear-gradient(to bottom, #fff 1px, transparent 1px); background-size: 80px 80px;"
  >
  </div>

  <div
    class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full blur-3xl opacity-20 pointer-events-none"
    style="background: radial-gradient(circle, var(--color-byl-yellow) 0%, transparent 70%);"
  >
  </div>

  <div class="container-page relative pt-20 pb-24 md:pt-28 md:pb-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <span class="eyebrow-on-dark">
          <span class="inline-block w-2 h-2 rounded-full bg-byl-yellow animate-pulse"></span>
          Officina · Carrozzeria · Vendita Auto
        </span>

        <h1 class="h-display mt-6">
          La tua auto, <span class="text-byl-yellow">come nuova</span>.
        </h1>

        <p class="lede mt-6 text-white/70">
          Un'unica squadra per la meccanica, la carrozzeria e la tua
          prossima auto. Officina autorizzata a Milano, carrozzeria con
          verniciatura a forno ad acqua a Mazzo di Rho, auto selezionate
          e pronte alla consegna.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href="#contatti" class="btn-primary">
            Prenota un servizio
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
          <a href="/auto/" class="btn-ghost">Vedi le auto in vendita</a>
        </div>

        <div class="mt-14 grid grid-cols-3 gap-6 max-w-xl">
          <div class="border-l-2 border-byl-yellow pl-4">
            <div class="text-xs uppercase tracking-wider text-white/50">Officina</div>
            <div class="mt-1 font-semibold text-white">Autorizzata</div>
          </div>
          <div class="border-l-2 border-byl-yellow pl-4">
            <div class="text-xs uppercase tracking-wider text-white/50">Carrozzeria</div>
            <div class="mt-1 font-semibold text-white">Forno ad acqua</div>
          </div>
          <div class="border-l-2 border-byl-yellow pl-4">
            <div class="text-xs uppercase tracking-wider text-white/50">Preventivi</div>
            <div class="mt-1 font-semibold text-white">Senza impegno</div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-5 relative">
        <div
          id="hero-carousel"
          class="relative aspect-[4/5] rounded-2xl overflow-hidden bg-byl-graphite border border-white/5"
        >
          {
            slides.map((s, i) => (
              <picture
                class="hero-slide absolute inset-0"
                data-index={i}
                data-active={i === 0 ? 'true' : 'false'}
              >
                <source srcset={`/photos/${s.base}.avif`} type="image/avif" />
                <source srcset={`/photos/${s.base}.webp`} type="image/webp" />
                <img
                  src={`/photos/${s.base}.jpg`}
                  alt={s.alt}
                  class="absolute inset-0 w-full h-full object-cover"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </picture>
            ))
          }

          <div class="absolute inset-0 bg-gradient-to-t from-byl-black/60 via-transparent to-transparent pointer-events-none"></div>

          <div class="absolute top-6 left-6 bg-byl-yellow text-byl-black px-3 py-1.5 text-xs font-bold uppercase tracking-wider rounded-sm">
            Auto selezionate
          </div>

          <div class="absolute bottom-5 left-1/2 -translate-x-1/2 flex gap-2">
            {
              slides.map((_, i) => (
                <button
                  class="hero-dot w-8 h-1.5 rounded-full bg-white/30 hover:bg-white/60 transition-colors"
                  data-dot={i}
                  aria-label={`Vai alla slide ${i + 1}`}
                />
              ))
            }
          </div>
        </div>

        <div class="hidden md:block absolute -bottom-6 -left-6 bg-byl-white text-byl-black p-5 rounded-xl shadow-2xl max-w-[240px]">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-byl-yellow flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div>
              <div class="font-semibold text-sm">Storia verificata</div>
              <div class="text-xs text-byl-mute">Controllate dai nostri tecnici</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-slide {
    opacity: 0;
    transition: opacity 900ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .hero-slide[data-active='true'] {
    opacity: 1;
  }
  .hero-dot[data-active='true'] {
    background: var(--color-byl-yellow);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-slide {
      transition: none;
    }
  }
</style>

<script>
  const root = document.getElementById('hero-carousel');
  if (root) {
    const slides = root.querySelectorAll<HTMLElement>('.hero-slide');
    const dots = root.querySelectorAll<HTMLButtonElement>('.hero-dot');
    let idx = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    const setActive = (i: number) => {
      idx = (i + slides.length) % slides.length;
      slides.forEach((s, j) => s.setAttribute('data-active', j === idx ? 'true' : 'false'));
      dots.forEach((d, j) => d.setAttribute('data-active', j === idx ? 'true' : 'false'));
    };

    const start = () => {
      if (timer) return;
      timer = setInterval(() => setActive(idx + 1), 5000);
    };
    const stop = () => {
      if (timer) clearInterval(timer);
      timer = null;
    };

    dots.forEach((d, i) =>
      d.addEventListener('click', () => {
        setActive(i);
        stop();
        start();
      })
    );

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);

    setActive(0);
    if (!matchMedia('(prefers-reduced-motion: reduce)').matches) start();
  }
</script>
