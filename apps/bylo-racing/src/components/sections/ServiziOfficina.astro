---
const servizi = [
  {
    title: 'Revisioni ministeriali',
    body: 'Revisioni per tutti i veicoli fino a 35 quintali, con pratica ministeriale gestita in sede.',
    icon: 'clipboard',
  },
  {
    title: 'Tagliandi multimarca',
    body: 'Tagliandi eseguiti secondo le specifiche delle case costruttrici. Garanzia originale sempre preservata.',
    icon: 'wrench',
  },
  {
    title: 'Meccanica & elettronica',
    body: 'Diagnosi e riparazione di guasti meccanici ed elettronici per privati e flotte aziendali.',
    icon: 'cpu',
  },
  {
    title: 'Servizio pneumatici',
    body: 'Controllo, fornitura, montaggio, equilibratura e cambio stagionale. Stoccaggio gomme su richiesta.',
    icon: 'tire',
  },
  {
    title: 'Igienizzazione & pulizia',
    body: 'Sanificazione degli interni e pulizia professionale della vettura. Auto sempre pronta alla consegna.',
    icon: 'spray',
  },
  {
    title: 'Auto sostitutiva',
    body: 'Auto di cortesia disponibile durante la lavorazione, così la tua mobilità non si ferma.',
    icon: 'car',
  },
];

const icons: Record<string, string> = {
  clipboard: '<path d="M9 2h6a2 2 0 0 1 2 2v1h3v17H4V5h3V4a2 2 0 0 1 2-2z"></path><path d="M9 4h6"></path><path d="M8 11h8M8 15h8M8 19h5"></path>',
  wrench: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>',
  cpu: '<rect x="4" y="4" width="16" height="16" rx="2"></rect><rect x="9" y="9" width="6" height="6"></rect><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3"></path>',
  tire: '<circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="4"></circle><path d="M12 2v4M12 18v4M2 12h4M18 12h4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"></path>',
  spray: '<path d="M3 6h6v4a3 3 0 0 1-3 3h0a3 3 0 0 1-3-3V6z"></path><path d="M9 8h4M9 12h4"></path><circle cx="17" cy="7" r="1"></circle><circle cx="20" cy="10" r="1"></circle><circle cx="17" cy="13" r="1"></circle><circle cx="21" cy="15" r="1"></circle><circle cx="19" cy="18" r="1"></circle>',
  car: '<path d="M5 11l1.5-4.5A2 2 0 0 1 8.4 5h7.2a2 2 0 0 1 1.9 1.5L19 11"></path><rect x="3" y="11" width="18" height="7" rx="2"></rect><circle cx="7" cy="18" r="1.5"></circle><circle cx="17" cy="18" r="1.5"></circle>',
};
---

<section id="officina" class="section-pad bg-byl-off">
  <div class="container-page">
    <div class="max-w-3xl">
      <span class="eyebrow">Officina autorizzata</span>
      <h2 class="h-section mt-4">
        La cura della tua auto, <span class="text-byl-yellow-dark">in un posto solo</span>.
      </h2>
      <p class="lede mt-6">
        Dalla revisione ministeriale al tagliando, dalla diagnosi elettronica
        al cambio gomme: tutto quello che serve alla tua auto, gestito da
        tecnici qualificati in una sola officina.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        servizi.map((s) => (
          <div class="group relative p-7 rounded-xl bg-white border border-byl-stone hover:border-byl-black hover:shadow-[var(--shadow-hover)] transition-all">
            <div class="w-12 h-12 rounded-lg bg-byl-black text-byl-yellow flex items-center justify-center group-hover:bg-byl-yellow group-hover:text-byl-black transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon]} />
            </div>
            <h3 class="h-card mt-6">{s.title}</h3>
            <p class="mt-3 text-byl-mute leading-relaxed text-sm">{s.body}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-12 text-center">
      <a href="#contatti" class="btn-outline">
        Richiedi un preventivo officina
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
  </div>
</section>
