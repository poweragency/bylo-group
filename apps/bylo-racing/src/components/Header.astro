---
const currentLocale = (Astro.currentLocale ?? 'it') as 'it' | 'en';
const isEN = currentLocale === 'en';

const t = {
  it: {
    servizi: 'Servizi',
    marche: 'Marche',
    zone: 'Zone',
    auto: 'Le nostre auto',
    contatti: 'Contatti',
    cta: 'Prenota un servizio',
    home: 'Tommy By — home',
    menuLabel: 'Apri menu',
    switchLabel: 'English',
  },
  en: {
    servizi: 'Services',
    marche: 'Brands',
    zone: 'Zones',
    auto: 'Our cars',
    contatti: 'Contact',
    cta: 'Book a service',
    home: 'Tommy By — home',
    menuLabel: 'Open menu',
    switchLabel: 'Italiano',
  },
}[currentLocale];

const base = isEN ? '/en' : '';
const sectionPath = isEN ? {
  servizi: '/en/services/',
  marche: '/en/brands/',
  zone: '/en/zones/',
  auto: '/en/auto/',
} : {
  servizi: '/servizi/',
  marche: '/marche/',
  zone: '/zone/',
  auto: '/auto/',
};
const contattiAnchor = `${base}/#contatti`;

const nav = [
  { href: sectionPath.servizi, label: t.servizi },
  { href: sectionPath.marche, label: t.marche },
  { href: sectionPath.zone, label: t.zone },
  { href: sectionPath.auto, label: t.auto },
  { href: contattiAnchor, label: t.contatti },
];

const switchHref = isEN
  ? Astro.url.pathname.replace(/^\/en(\/|$)/, '/')
  : `/en${Astro.url.pathname === '/' ? '' : Astro.url.pathname}`;
---

<header
  class="sticky top-0 z-50 bg-byl-black/90 backdrop-blur-md border-b border-white/5 text-byl-white"
>
  <div class="container-page flex items-center justify-between h-16 md:h-20">
    <a href={base || '/'} class="flex items-baseline gap-1.5" aria-label={t.home}>
      <span class="font-display font-black text-2xl md:text-3xl tracking-tight text-byl-yellow">
        Tommy
      </span>
      <span class="font-display font-light text-xl md:text-2xl tracking-[0.2em] uppercase text-byl-white/70">
        By
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-8">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-white/80 hover:text-byl-yellow transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={switchHref}
        class="text-xs uppercase tracking-wider font-medium text-white/60 hover:text-byl-yellow transition-colors"
        aria-label={t.switchLabel}
      >
        {isEN ? 'IT' : 'EN'}
      </a>
      <a href={contattiAnchor} class="btn-primary hidden sm:inline-flex text-sm">
        {t.cta}
      </a>
      <button
        id="mobile-menu-btn"
        class="lg:hidden -mr-2 p-2.5 text-byl-white rounded-md hover:bg-white/10 transition-colors"
        aria-label={t.menuLabel}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden border-t border-white/10 bg-byl-black">
    <nav class="container-page py-4 flex flex-col gap-1">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="py-3 text-base font-medium text-white/80 hover:text-byl-yellow"
          >
            {item.label}
          </a>
        ))
      }
      <a href={switchHref} class="py-3 text-base font-medium text-white/60 hover:text-byl-yellow">
        {t.switchLabel}
      </a>
      <a href={contattiAnchor} class="btn-primary mt-3 text-sm w-full">
        {t.cta}
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(isHidden === false));
  });
</script>
