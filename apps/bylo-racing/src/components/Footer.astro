---
import { BRAND_RACING, CONTACTS_RACING, GROUP } from '@bylo/ui/index.ts';
const year = new Date().getFullYear();
const { officina, carrozzeria } = CONTACTS_RACING;

const currentLocale = (Astro.currentLocale ?? 'it') as 'it' | 'en';
const isEN = currentLocale === 'en';
const base = isEN ? '/en' : '';

const t = isEN
  ? {
      tagline:
        'Authorized auto repair shop, body shop with water-based oven painting, and selected used car sales. Tommy By is part of',
      taglineSuffix:
        ', the Italian network dedicated to transport, logistics and automotive.',
      explore: 'Explore',
      services: 'Services',
      brands: 'Brands',
      zones: 'Zones',
      cars: 'Our cars',
      vat: 'VAT',
      privacy: 'Privacy',
      cookie: 'Cookie',
      cookiePrefs: 'Cookie preferences',
    }
  : {
      tagline:
        'Officina autorizzata, carrozzeria con verniciatura a forno ad acqua e vendita auto selezionate. Tommy By fa parte di',
      taglineSuffix:
        ', rete italiana dedicata a trasporti, logistica e automotive.',
      explore: 'Esplora',
      services: 'Servizi',
      brands: 'Marche',
      zones: 'Zone',
      cars: 'Le nostre auto',
      vat: 'P.IVA',
      privacy: 'Privacy',
      cookie: 'Cookie',
      cookiePrefs: 'Preferenze cookie',
    };

const sectionPath = isEN ? {
  servizi: '/en/services/',
  marche: '/en/brands/',
  zone: '/en/zones/',
  auto: '/en/auto/',
} : {
  servizi: '/servizi/',
  marche: '/marche/',
  zone: '/zone/',
  auto: '/auto/',
};
---

<footer class="bg-byl-black text-byl-white">
  <div class="container-page py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-4">
        <div class="flex items-baseline gap-1.5">
          <span class="font-display font-black text-3xl md:text-4xl tracking-tight text-byl-yellow">
            Tommy
          </span>
          <span class="font-display font-light text-2xl tracking-[0.2em] uppercase text-byl-white/70">
            By
          </span>
        </div>
        <p class="mt-6 text-white/60 max-w-md leading-relaxed text-sm">
          {t.tagline} {GROUP.name}{t.taglineSuffix}
        </p>
      </div>

      <div class="md:col-span-3">
        <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-byl-yellow">
          {officina.label}
        </h4>
        <p class="mt-4 text-white/80 leading-relaxed text-sm">
          {officina.address}<br />
          <a href={`tel:${officina.phone.replace(/\s/g, '')}`} class="inline-block py-1 hover:text-byl-yellow transition-colors">{officina.phone}</a><br />
          <a href={`mailto:${officina.email}`} class="inline-block py-1 hover:text-byl-yellow transition-colors">{officina.email}</a>
        </p>
      </div>

      <div class="md:col-span-3">
        <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-byl-yellow">
          {carrozzeria.label}
        </h4>
        <p class="mt-4 text-white/80 leading-relaxed text-sm">
          {carrozzeria.address}<br />
          <a href={`tel:${carrozzeria.phone.replace(/\s/g, '')}`} class="inline-block py-1 hover:text-byl-yellow transition-colors">{carrozzeria.phone}</a><br />
          <a href={`mailto:${carrozzeria.email}`} class="inline-block py-1 hover:text-byl-yellow transition-colors">{carrozzeria.email}</a>
        </p>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-byl-yellow">
          {t.explore}
        </h4>
        <ul class="mt-4 space-y-2 text-white/80 text-sm">
          <li><a href={sectionPath.servizi} class="hover:text-byl-yellow transition-colors">{t.services}</a></li>
          <li><a href={sectionPath.marche} class="hover:text-byl-yellow transition-colors">{t.brands}</a></li>
          <li><a href={sectionPath.zone} class="hover:text-byl-yellow transition-colors">{t.zones}</a></li>
          <li><a href={sectionPath.auto} class="hover:text-byl-yellow transition-colors">{t.cars}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row md:items-center justify-between gap-4 text-sm text-white/50">
      <p>© {year} {BRAND_RACING.legalName} — {t.vat} {BRAND_RACING.vat}</p>
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        <a href={GROUP.website} class="hover:text-byl-yellow transition-colors">{GROUP.name}</a>
        <a href={`${base}/privacy`} class="hover:text-byl-yellow transition-colors">{t.privacy}</a>
        <a href={`${base}/cookie`} class="hover:text-byl-yellow transition-colors">{t.cookie}</a>
        <button type="button" data-cc-action="open-preferences" class="hover:text-byl-yellow transition-colors">{t.cookiePrefs}</button>
      </div>
    </div>
  </div>
</footer>
