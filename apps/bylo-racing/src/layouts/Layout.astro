---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { Seo, Hreflang } from '@bylo/ui/seo/index.ts';
import { BRAND_RACING } from '@bylo/ui/index.ts';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const currentLocale = (Astro.currentLocale ?? 'it') as 'it' | 'en';
const isEN = currentLocale === 'en';
const ogLocale = isEN ? 'en_US' : 'it_IT';
const htmlLang = isEN ? 'en' : 'it';

const defaultTitle = isEN
  ? 'Tommy By — Auto Repair, Body Shop and Used Car Sales near Milan'
  : 'Tommy By — Officina, Carrozzeria e Vendita Auto a Milano';
const defaultDescription = isEN
  ? 'Multi-brand authorized auto repair shop, body shop with water-based oven painting, and selected used car sales. Tommy By, in Rho near Milan.'
  : 'Officina autorizzata multimarca, carrozzeria con verniciatura a forno ad acqua e vendita auto selezionate. Tommy By, a Milano e Mazzo di Rho.';

const {
  title = defaultTitle,
  description = defaultDescription,
  ogImage,
  noindex,
} = Astro.props;

const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? '';
const path = Astro.url.pathname;

function altUrl(target: 'it' | 'en'): string {
  if (target === 'it') {
    const stripped = path.replace(/^\/en(\/|$)/, '/');
    return `${siteOrigin}${stripped}`;
  }
  if (path.startsWith('/en/') || path === '/en') {
    return `${siteOrigin}${path}`;
  }
  return `${siteOrigin}/en${path === '/' ? '' : path}`;
}

const alternates = [
  { hreflang: 'it', href: altUrl('it') },
  { hreflang: 'en', href: altUrl('en') },
];
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <Seo
      title={title}
      description={description}
      ogImage={ogImage}
      locale={ogLocale}
      noindex={noindex}
      siteName={BRAND_RACING.name}
    />
    <Hreflang alternates={alternates} xDefault={altUrl('it')} />
  </head>
  <body class="bg-byl-white text-byl-black antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
