---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { Seo, Hreflang, SchemaOrg } from '@bylo/ui/seo/index.ts';
import CookieBanner from '@bylo/ui/legal/CookieBanner.astro';
import GoogleAnalytics from '@bylo/ui/analytics/GoogleAnalytics.astro';
import BackToTop from '@bylo/ui/components/BackToTop.astro';
import SkipToContent from '@bylo/ui/components/SkipToContent.astro';
import {
  BRAND_RACING,
  GROUP,
  LEGAL_TOMMY,
  CONTACTS_RACING,
} from '@bylo/ui/index.ts';
import { i18nRoutes } from '@/lib/i18n-routes';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const currentLocale = (Astro.currentLocale ?? 'it') as 'it' | 'en';
const isEN = currentLocale === 'en';
const ogLocale = isEN ? 'en_US' : 'it_IT';
const htmlLang = isEN ? 'en' : 'it';

const defaultTitle = isEN
  ? 'Tommy By — Auto Repair, Body Shop and Used Car Sales near Milan'
  : 'Tommy By — Officina, Carrozzeria e Vendita Auto a Mazzo di Rho';
const defaultDescription = isEN
  ? 'Multi-brand authorized auto repair shop, body shop with water-based oven painting, and selected used car sales. Tommy By (formerly BYLO Racing), in Mazzo di Rho near Milan.'
  : 'Officina autorizzata multimarca, carrozzeria con verniciatura a forno ad acqua e vendita auto selezionate. Tommy By (già BYLO Racing), a Mazzo di Rho (alle porte di Milano).';

const {
  title = defaultTitle,
  description = defaultDescription,
  ogImage = '/og-default.png',
  noindex,
} = Astro.props;

const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? '';
const path = Astro.url.pathname;

// hreflang basati sulla controparte REALE (segmento + slug tradotti). Quando la
// pagina non ha controparte (es. schede /auto/), l'alternato viene omesso
// invece di puntare a un 404.
const itPath = i18nRoutes.alternateUrl(path, 'it');
const enPath = i18nRoutes.alternateUrl(path, 'en');
const alternates = [
  ...(itPath ? [{ hreflang: 'it', href: `${siteOrigin}${itPath}` }] : []),
  ...(enPath ? [{ hreflang: 'en', href: `${siteOrigin}${enPath}` }] : []),
];
const xDefaultHref = `${siteOrigin}${itPath ?? enPath ?? path}`;

const standardHours = [
  {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '08:30',
    closes: '12:30',
  },
  {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '14:00',
    closes: '18:00',
  },
];

// Coordinate sede di Mazzo di Rho (Via Venanzio Buzzi 9). Approssimate sul
// civico: confermare/affinare col Google Business Profile quando il cliente
// trasferisce l'ownership degli asset Google.
const SEDE_GEO = {
  '@type': 'GeoCoordinates',
  latitude: 45.5247,
  longitude: 9.0089,
};

// Bacino di utenza locale dichiarato (coerente con le pagine /zone): Mazzo di
// Rho, Rho e la citta' metropolitana di Milano. Leva per il Local Pack/Maps.
const AREA_SERVED = [
  { '@type': 'City', name: 'Mazzo di Rho' },
  { '@type': 'City', name: 'Rho' },
  { '@type': 'AdministrativeArea', name: 'Città metropolitana di Milano' },
];

// 2 LocalBusiness distinte (AutoRepair + AutoBodyShop) coabitanti nella
// stessa sede di Mazzo di Rho. Entry separate per dare a Google entita'
// distinte sui due servizi.
const officinaSchema = {
  '@context': 'https://schema.org',
  '@type': 'AutoRepair',
  '@id': `${siteOrigin}/#officina`,
  name: `${BRAND_RACING.name} — Officina`,
  alternateName: BRAND_RACING.formerName,
  legalName: LEGAL_TOMMY.name,
  url: siteOrigin,
  logo: `${siteOrigin}/logo.png`,
  vatID: LEGAL_TOMMY.vat,
  parentOrganization: {
    '@type': 'Organization',
    name: GROUP.name,
    url: GROUP.website,
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via Venanzio Buzzi 9',
    postalCode: '20017',
    addressLocality: 'Mazzo di Rho',
    addressRegion: 'MI',
    addressCountry: 'IT',
  },
  telephone: CONTACTS_RACING.officina.phone,
  email: CONTACTS_RACING.officina.email,
  openingHoursSpecification: standardHours,
  geo: SEDE_GEO,
  areaServed: AREA_SERVED,
  description: isEN
    ? 'Multi-brand authorized workshop for cars and motorcycles in Mazzo di Rho (Milan). Scheduled services with official manufacturer warranty, mechanical and electronic repairs, tires, vehicle sanitization, replacement cars. Mandatory inspections up to 3.5 tons.'
    : 'Officina autorizzata multimarche per auto e moto a Mazzo di Rho (MI). Tagliandi con garanzie ufficiali delle case, riparazioni meccaniche ed elettroniche, pneumatici, igienizzazione, auto sostitutive. Revisioni ministeriali fino a 35 quintali.',
};

const carrozzeriaSchema = {
  '@context': 'https://schema.org',
  '@type': 'AutoBodyShop',
  '@id': `${siteOrigin}/#carrozzeria`,
  name: `${BRAND_RACING.name} — Carrozzeria`,
  alternateName: BRAND_RACING.formerName,
  legalName: LEGAL_TOMMY.name,
  url: siteOrigin,
  logo: `${siteOrigin}/logo.png`,
  vatID: LEGAL_TOMMY.vat,
  parentOrganization: {
    '@type': 'Organization',
    name: GROUP.name,
    url: GROUP.website,
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via Venanzio Buzzi 9',
    postalCode: '20017',
    addressLocality: 'Mazzo di Rho',
    addressRegion: 'MI',
    addressCountry: 'IT',
  },
  telephone: CONTACTS_RACING.carrozzeria.phone,
  email: CONTACTS_RACING.carrozzeria.email,
  openingHoursSpecification: standardHours,
  geo: SEDE_GEO,
  areaServed: AREA_SERVED,
  description: isEN
    ? 'Body shop with water-based oven painting in Mazzo di Rho (Milan). Collision repairs, full repainting, professional spectrophotometer for precise color matching.'
    : 'Carrozzeria con verniciatura a forno ad acqua a Mazzo di Rho (MI). Riparazioni post-sinistro, verniciatura completa, tintometro professionale per abbinamento tinta preciso.',
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Tommy By" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://rsms.me/" crossorigin />
    <link rel="preload" href="https://rsms.me/inter/inter.css" as="style" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://rsms.me/inter/inter.css" /></noscript>

    <Seo
      title={title}
      description={description}
      ogImage={ogImage}
      locale={ogLocale}
      noindex={noindex}
      siteName={BRAND_RACING.name}
    />
    <Hreflang alternates={alternates} xDefault={xDefaultHref} />
    <SchemaOrg data={officinaSchema} />
    <SchemaOrg data={carrozzeriaSchema} />
    <GoogleAnalytics />
  </head>
  <body class="bg-byl-white text-byl-black antialiased">
    <SkipToContent locale={currentLocale} />
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <BackToTop />
    <CookieBanner />
  </body>
</html>
