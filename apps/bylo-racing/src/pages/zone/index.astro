---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { Breadcrumb } from '@bylo/ui/seo/index.ts';

const zones = await getCollection('zones', ({ data }) => data.locale === 'it');
zones.sort((a, b) => a.data.name.localeCompare(b.data.name));

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Zone servite', href: '/zone/' },
];
---

<Layout
  title="Zone servite — Tommy By"
  description="Le zone servite da Tommy By: Milano, Rho, Pero, Arese, Lainate. Sede unica a Mazzo di Rho (Via Venanzio Buzzi 9), alle porte di Milano."
>
  <Breadcrumb items={crumbs} />

  <section class="section-pad bg-byl-black text-byl-white">
    <div class="container-page">
      <span class="eyebrow text-byl-yellow">Zone servite</span>
      <h1 class="h-display mt-4">
        Dove arriviamo nel <span class="text-byl-yellow">nord-ovest milanese</span>.
      </h1>
      <p class="lede mt-6 text-white/70 max-w-2xl">
        Le zone tipiche dei nostri clienti, fra Milano e l'hinterland nord-ovest. La nostra sede di Mazzo di Rho copre comodamente l'intera area.
      </p>
    </div>
  </section>

  <section class="section-pad bg-byl-white">
    <div class="container-page">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {zones.map((z) => (
          <a
            href={`/zone/${z.slug.split('/').pop()}/`}
            class="group block p-6 rounded-2xl border border-byl-stone bg-byl-white hover:border-byl-black hover:shadow-[var(--shadow-hover)] transition-all"
          >
            <span class="text-xs uppercase tracking-wider text-byl-mute font-semibold">{z.data.province}</span>
            <h2 class="font-display font-bold text-2xl text-byl-black mt-1">
              {z.data.name}
            </h2>
            <p class="mt-3 text-sm text-byl-mute leading-relaxed line-clamp-3">
              {z.data.intro}
            </p>
            <div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-byl-black group-hover:text-byl-yellow-dark transition-colors">
              Dettagli
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
