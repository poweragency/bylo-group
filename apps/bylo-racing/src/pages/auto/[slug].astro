---
import Layout from '@/layouts/Layout.astro';
import { cars, formatPrice, formatKm, formatFuel } from '@/lib/cars';

export function getStaticPaths() {
  return cars.map((car) => ({
    params: { slug: car.slug },
    props: { car },
  }));
}

const { car } = Astro.props;
const title = `${car.brand} ${car.model} ${car.version ?? ''} — Tommy Racing`;
const description = `${car.brand} ${car.model} ${car.version ?? ''}, ${car.year}, ${formatKm(car.km)}, ${formatFuel(car.fuel)}. In vendita presso Tommy Racing a ${formatPrice(car.price)}.`;

const specs = [
  { label: 'Anno', value: car.year },
  { label: 'Chilometri', value: formatKm(car.km) },
  { label: 'Alimentazione', value: formatFuel(car.fuel) },
  { label: 'Cambio', value: car.transmission, capitalize: true },
  { label: 'Potenza', value: `${car.power_cv} CV (${car.power_kw} kW)` },
  { label: 'Colore', value: car.color },
];
---

<Layout title={title} description={description}>
  <section class="bg-byl-white pt-8 pb-4">
    <div class="container-page">
      <nav class="text-sm text-byl-mute flex items-center gap-2">
        <a href="/" class="hover:text-byl-black transition-colors">Home</a>
        <span>/</span>
        <a href="/auto/" class="hover:text-byl-black transition-colors">Le nostre auto</a>
        <span>/</span>
        <span class="text-byl-black">{car.brand} {car.model}</span>
      </nav>
    </div>
  </section>

  <section class="bg-byl-white pb-24">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        <div class="lg:col-span-7">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-byl-stone">
            <img src={car.image} alt={`${car.brand} ${car.model}`} class="w-full h-full object-cover" loading="eager" />
          </div>
        </div>

        <div class="lg:col-span-5">
          <div class="sticky top-24">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="bg-byl-yellow text-byl-black px-2.5 py-1 text-xs font-bold uppercase tracking-wider rounded-sm">
                {formatFuel(car.fuel)}
              </span>
              <span class="bg-byl-black text-byl-yellow px-2.5 py-1 text-xs font-bold uppercase tracking-wider rounded-sm capitalize">
                {car.transmission}
              </span>
            </div>

            <h1 class="h-section mt-4">{car.brand} {car.model}</h1>
            {car.version && <p class="mt-2 text-lg text-byl-mute">{car.version}</p>}

            <div class="mt-6 pb-6 border-b border-byl-stone">
              <div class="font-display font-bold text-4xl text-byl-black">{formatPrice(car.price)}</div>
            </div>

            <dl class="mt-6 grid grid-cols-2 gap-y-5 gap-x-4 text-sm">
              {specs.map((spec) => (
                <div>
                  <dt class="text-byl-mute uppercase tracking-wider text-xs">{spec.label}</dt>
                  <dd class:list={['mt-1 font-semibold text-byl-black', spec.capitalize && 'capitalize']}>
                    {spec.value}
                  </dd>
                </div>
              ))}
            </dl>

            <div class="mt-8 space-y-3">
              <a href="#contatti" class="btn-primary w-full">
                Richiedi informazioni
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </a>
              {car.as24_url && (
                <a href={car.as24_url} target="_blank" rel="noopener noreferrer" class="btn-outline w-full">
                  Vedi annuncio su AutoScout24
                </a>
              )}
            </div>
          </div>
        </div>
      </div>

      <div class="mt-16 max-w-3xl">
        <h2 class="h-card">Descrizione</h2>
        <p class="mt-4 text-byl-mute leading-relaxed whitespace-pre-line">{car.description}</p>
      </div>
    </div>
  </section>

  <section id="contatti" class="bg-byl-off py-16">
    <div class="container-page text-center max-w-2xl mx-auto">
      <span class="eyebrow">Interessato a questa auto?</span>
      <h2 class="h-section mt-4">Chiamaci o scrivici, <span class="text-byl-yellow-dark">ti aspettiamo</span>.</h2>
      <p class="lede mt-4 mx-auto">Possiamo organizzare una prova su strada, un appuntamento in sede o una videochiamata di presentazione del veicolo.</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contatti" class="btn-primary">Vai al modulo contatti</a>
        <a href="tel:+390233490890" class="btn-outline">Chiama ora</a>
      </div>
    </div>
  </section>
</Layout>
