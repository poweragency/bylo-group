---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { InternalLinkBlock } from '@bylo/ui/seo/index.ts';
import Hero from '@/components/sections/Hero.astro';
import ChiSiamo from '@/components/sections/ChiSiamo.astro';
import ServiziTrasporti from '@/components/sections/ServiziTrasporti.astro';
import RotteEuropa from '@/components/sections/RotteEuropa.astro';
import ServiziLogistica from '@/components/sections/ServiziLogistica.astro';
import PercheBYL from '@/components/sections/PercheBYL.astro';
import CtaFinale from '@/components/sections/CtaFinale.astro';
import Contatti from '@/components/sections/Contatti.astro';
import DoveSiamo from '@/components/sections/DoveSiamo.astro';

// Link "editoriali" dalla home (massima autorita') verso le pagine di
// dettaglio: la home distribuisce link equity agli spoke long-tail
// (servizi/settori/tratte), che altrimenti ricevono link solo da nav/footer.
// Generati dalle collection -> sempre completi e in sync.
const slugOf = (s) => s.split('/').pop();
const trunc = (s, n = 120) => {
  const c = s.replace(/\s+/g, ' ').trim();
  return c.length > n ? c.slice(0, n).replace(/\s+\S*$/, '') + '…' : c;
};
const bySlug = (a, b) => a.slug.localeCompare(b.slug);

const services = (await getCollection('services', ({ data }) => data.locale === 'it')).sort(bySlug);
const sectors = (await getCollection('sectors', ({ data }) => data.locale === 'it')).sort(bySlug);
const routes = (await getCollection('routes', ({ data }) => data.locale === 'it')).sort(bySlug);

const serviziLinks = services.map((s) => ({
  href: `/servizi/${slugOf(s.slug)}/`,
  label: s.data.title,
  description: trunc(s.data.intro),
}));
const settoriLinks = sectors.map((s) => ({
  href: `/settori/${slugOf(s.slug)}/`,
  label: s.data.title,
  description: trunc(s.data.intro),
}));
const tratteLinks = routes.map((r) => ({
  href: `/tratte/${slugOf(r.slug)}/`,
  label: `${r.data.origin}–${r.data.destination}`,
  description: r.data.distanceKm
    ? `~${r.data.distanceKm} km${r.data.transitTimeHours ? `, ~${r.data.transitTimeHours} h di guida` : ''}`
    : undefined,
}));
---

<Layout>
  <Hero />
  <ChiSiamo />
  <ServiziTrasporti />
  <RotteEuropa />
  <ServiziLogistica />
  <PercheBYL />

  <InternalLinkBlock
    title="I nostri servizi di trasporto e logistica"
    eyebrow="Approfondisci"
    links={serviziLinks}
    columns={3}
  />
  <InternalLinkBlock
    title="Settori che serviamo"
    eyebrow="Esperienza verticale"
    links={settoriLinks}
    columns={3}
  />
  <InternalLinkBlock
    title="Tratte ADR più richieste"
    eyebrow="Dove operiamo"
    links={tratteLinks}
    columns={2}
  />

  <CtaFinale />
  <Contatti />
  <DoveSiamo />
</Layout>
