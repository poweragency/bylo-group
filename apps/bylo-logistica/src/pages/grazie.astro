---
import Layout from '@/layouts/Layout.astro';
import { CONTACTS } from '@bylo/ui/index.ts';
---

<Layout
  title="Richiesta inviata — BYLO Transport"
  description="Grazie per averci contattato. Ti rispondiamo entro 24 ore lavorative."
  noindex={true}
>
  <section class="section-pad">
    <div class="container-page max-w-2xl text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-byl-yellow/15 mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-byl-yellow-dark" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <span class="eyebrow">Richiesta ricevuta</span>
      <h1 class="h-section mt-4">Grazie! Ti rispondiamo <span class="text-byl-yellow-dark">entro 24 ore</span>.</h1>
      <p class="lede mt-6 mx-auto">
        Abbiamo registrato la tua richiesta e il nostro team operativo la sta già esaminando.
        Riceverai una proposta concreta entro le prossime 24 ore lavorative.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">Torna alla home</a>
        <a href={`tel:${CONTACTS.hq.phone.replace(/\s/g, '')}`} class="btn-outline">Chiama subito {CONTACTS.hq.phone}</a>
      </div>
    </div>
  </section>
</Layout>
