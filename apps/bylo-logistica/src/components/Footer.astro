---
import { BRAND, CONTACTS } from '@bylo/ui/index.ts';
const year = new Date().getFullYear();
---

<footer class="bg-byl-black text-byl-white">
  <div class="container-page py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-5">
        <img
          src="/logo.png"
          alt="BYL Logistica"
          width="275"
          height="124"
          class="h-14 w-auto"
        />
        <p class="mt-6 text-white/60 max-w-md leading-relaxed">
          Trasporti ADR e logistica integrata per le imprese italiane.
          Parte del gruppo BYLO Group, rete di aziende dedicate a
          trasporti, logistica e automotive.
        </p>
        <div class="mt-8 flex items-center gap-4">
          <a
            href={`mailto:${CONTACTS.hq.email}`}
            class="text-sm text-white/80 hover:text-byl-yellow transition-colors"
          >
            {CONTACTS.hq.email}
          </a>
          <span class="text-white/30">·</span>
          <a
            href={`tel:${CONTACTS.hq.phone.replace(/\s/g, '')}`}
            class="text-sm text-white/80 hover:text-byl-yellow transition-colors"
          >
            {CONTACTS.hq.phone}
          </a>
        </div>
      </div>

      <div class="md:col-span-4">
        <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-byl-yellow">
          Sede operativa
        </h4>
        <p class="mt-4 text-white/80 leading-relaxed">
          {CONTACTS.hq.label}<br />
          {CONTACTS.hq.address}
        </p>
        <p class="mt-3 text-sm text-white/50">{CONTACTS.hq.hours}</p>
      </div>

      <div class="md:col-span-3">
        <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-byl-yellow">
          Gruppo
        </h4>
        <ul class="mt-4 space-y-2 text-white/80 text-sm">
          <li><a href="https://www.bylogroup.it/" class="hover:text-byl-yellow transition-colors">BYLO Group</a></li>
          <li><a href="#servizi" class="hover:text-byl-yellow transition-colors">Trasporti ADR</a></li>
          <li><a href="#servizi" class="hover:text-byl-yellow transition-colors">Logistica</a></li>
          <li><a href="#contatti" class="hover:text-byl-yellow transition-colors">Contatti</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row md:items-center justify-between gap-4 text-sm text-white/50">
      <p>© {year} {BRAND.legalName} — P.IVA {BRAND.vat}</p>
      <div class="flex gap-6">
        <a href="/privacy" class="hover:text-byl-yellow transition-colors">Privacy Policy</a>
        <a href="/cookie" class="hover:text-byl-yellow transition-colors">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>
