---
import { BRAND, CONTACTS } from '@bylo/ui/index.ts';
const year = new Date().getFullYear();

const currentLocale = (Astro.currentLocale ?? 'it') as 'it' | 'en';
const isEN = currentLocale === 'en';
const base = isEN ? '/en' : '';

const t = isEN
  ? {
      tagline:
        'ADR transport and integrated logistics for Italian businesses. Part of BYLO Group, a network of companies dedicated to transport, logistics and automotive.',
      operativeHQ: 'Operating headquarters',
      group: 'Group',
      transports: 'ADR transport',
      logistics: 'Logistics',
      contact: 'Contact',
      privacy: 'Privacy Policy',
      cookie: 'Cookie Policy',
      vat: 'VAT',
    }
  : {
      tagline:
        'Trasporti ADR e logistica integrata per le imprese italiane. Parte del gruppo BYLO Group, rete di aziende dedicate a trasporti, logistica e automotive.',
      operativeHQ: 'Sede operativa',
      group: 'Gruppo',
      transports: 'Trasporti ADR',
      logistics: 'Logistica',
      contact: 'Contatti',
      privacy: 'Privacy Policy',
      cookie: 'Cookie Policy',
      vat: 'P.IVA',
    };
---

<footer class="bg-byl-black text-byl-white">
  <div class="container-page py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-5">
        <div class="flex items-baseline gap-2">
          <span class="font-display font-black text-3xl md:text-4xl tracking-tight text-byl-yellow">
            BYLO
          </span>
          <span class="font-display font-medium text-xl tracking-[0.22em] uppercase text-byl-white/80">
            Transport
          </span>
        </div>
        <p class="mt-6 text-white/60 max-w-md leading-relaxed">{t.tagline}</p>
        <div class="mt-8 flex items-center gap-4">
          <a
            href={`mailto:${CONTACTS.hq.email}`}
            class="text-sm text-white/80 hover:text-byl-yellow transition-colors"
          >
            {CONTACTS.hq.email}
          </a>
          <span class="text-white/30">·</span>
          <a
            href={`tel:${CONTACTS.hq.phone.replace(/\s/g, '')}`}
            class="text-sm text-white/80 hover:text-byl-yellow transition-colors"
          >
            {CONTACTS.hq.phone}
          </a>
        </div>
      </div>

      <div class="md:col-span-4">
        <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-byl-yellow">
          {t.operativeHQ}
        </h4>
        <p class="mt-4 text-white/80 leading-relaxed">
          {CONTACTS.hq.label}<br />
          {CONTACTS.hq.address}
        </p>
        <p class="mt-3 text-sm text-white/50">{CONTACTS.hq.hours}</p>
      </div>

      <div class="md:col-span-3">
        <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-byl-yellow">
          {t.group}
        </h4>
        <ul class="mt-4 space-y-2 text-white/80 text-sm">
          <li><a href="https://www.bylogroup.it/" class="hover:text-byl-yellow transition-colors">BYLO Group</a></li>
          <li><a href={`${base}/#servizi`} class="hover:text-byl-yellow transition-colors">{t.transports}</a></li>
          <li><a href={`${base}/#servizi`} class="hover:text-byl-yellow transition-colors">{t.logistics}</a></li>
          <li><a href={`${base}/#contatti`} class="hover:text-byl-yellow transition-colors">{t.contact}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row md:items-center justify-between gap-4 text-sm text-white/50">
      <p>© {year} {BRAND.legalName} — {t.vat} {BRAND.vat}</p>
      <div class="flex gap-6">
        <a href={`${base}/privacy`} class="hover:text-byl-yellow transition-colors">{t.privacy}</a>
        <a href={`${base}/cookie`} class="hover:text-byl-yellow transition-colors">{t.cookie}</a>
      </div>
    </div>
  </div>
</footer>
