---
import { EUROPE_VIEWBOX, EUROPE_PATHS } from '@bylo/ui/europe.ts';

const italyPath = EUROPE_PATHS.find((c) => c.name === 'Italy')!;
const otherPaths = EUROPE_PATHS.filter((c) => c.name !== 'Italy');

// Hub di partenza (Bollate, Milano) e principali destinazioni europee.
// Coordinate riferite al viewBox 0 0 1000 800 di EUROPE_PATHS.
const HUB = { x: 478, y: 478 };
const destinations = [
  { name: 'Parigi', x: 415, y: 425 },
  { name: 'Berlino', x: 530, y: 365 },
  { name: 'Madrid', x: 270, y: 580 },
  { name: 'Vienna', x: 525, y: 460 },
  { name: 'Roma', x: 518, y: 555 },
  { name: 'Amsterdam', x: 395, y: 365 },
  { name: 'Monaco', x: 490, y: 440 },
  { name: 'Varsavia', x: 615, y: 405 },
];
---

<section class="section-pad bg-byl-black text-byl-white relative overflow-hidden">
  <!-- Subtle grid pattern -->
  <div
    class="absolute inset-0 opacity-[0.04] pointer-events-none"
    style="background-image: linear-gradient(to right, #fff 1px, transparent 1px), linear-gradient(to bottom, #fff 1px, transparent 1px); background-size: 80px 80px;"
  >
  </div>

  <div class="container-page relative">
    <div class="max-w-3xl mx-auto text-center">
      <span class="eyebrow-on-dark justify-center">Copertura nazionale e internazionale</span>
      <h2 class="h-section mt-4 text-byl-white">
        Al servizio delle imprese <span class="text-byl-yellow">in Italia e in Europa</span>.
      </h2>
    </div>

    <div class="mt-16 relative mx-auto max-w-4xl">
      <svg
        viewBox={EUROPE_VIEWBOX}
        class="w-full h-auto"
        aria-hidden="true"
      >
        <defs>
          <linearGradient id="route-grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0"></stop>
            <stop offset="50%" stop-color="var(--color-byl-yellow)" stop-opacity="1"></stop>
            <stop offset="100%" stop-color="#ffffff" stop-opacity="0"></stop>
          </linearGradient>
        </defs>

        <!-- Other European countries (filled) -->
        <g fill="var(--color-byl-graphite)" stroke="rgba(255,255,255,0.15)" stroke-width="0.6" stroke-linejoin="round">
          {otherPaths.map((c) => <path d={c.d} />)}
        </g>

        <!-- Italy highlighted -->
        <path d={italyPath.d} fill="rgba(250, 204, 21, 0.18)" stroke="var(--color-byl-yellow)" stroke-width="1.2" stroke-linejoin="round" stroke-linecap="round" />

        <!-- Routes from Milano hub to destinations -->
        <g
          fill="none"
          stroke="url(#route-grad)"
          stroke-width="1.4"
          stroke-linecap="round"
        >
          {destinations.map((d, i) => {
            const mx = (HUB.x + d.x) / 2;
            const my = Math.min(HUB.y, d.y) - 30;
            return (
              <path
                class={`route-line route-${i + 1}`}
                d={`M${HUB.x},${HUB.y} Q${mx},${my} ${d.x},${d.y}`}
                style={`animation-delay: ${i * 0.35}s;`}
              />
            );
          })}
        </g>

        <!-- Destination markers -->
        <g>
          {destinations.map((d) => (
            <>
              <circle cx={d.x} cy={d.y} r="3" fill="var(--color-byl-yellow)" />
              <circle cx={d.x} cy={d.y} r="6" fill="none" stroke="var(--color-byl-yellow)" stroke-opacity="0.4" stroke-width="1">
                <animate attributeName="r" values="3;10;3" dur="2.4s" repeatCount="indefinite" />
                <animate attributeName="stroke-opacity" values="0.5;0;0.5" dur="2.4s" repeatCount="indefinite" />
              </circle>
            </>
          ))}
        </g>

        <!-- Milano hub -->
        <g>
          <circle cx={HUB.x} cy={HUB.y} r="4.5" fill="var(--color-byl-yellow)" />
          <circle cx={HUB.x} cy={HUB.y} r="9" fill="none" stroke="var(--color-byl-yellow)" stroke-width="1.4">
            <animate attributeName="r" values="5;14;5" dur="2s" repeatCount="indefinite" />
            <animate attributeName="stroke-opacity" values="0.9;0;0.9" dur="2s" repeatCount="indefinite" />
          </circle>
          <text x={HUB.x + 10} y={HUB.y - 6} font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="var(--color-byl-yellow)">Milano</text>
        </g>
      </svg>
    </div>
  </div>
</section>

<style>
  .eyebrow-on-dark {
    justify-content: center;
  }

  .route-line {
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
    animation: draw-route 6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes draw-route {
    0% {
      stroke-dashoffset: 400;
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    55% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    80% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    100% {
      stroke-dashoffset: -400;
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .route-line {
      animation: none;
      stroke-dashoffset: 0;
      opacity: 1;
    }
  }
</style>
