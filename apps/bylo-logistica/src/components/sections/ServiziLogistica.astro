---
const features = [
  {
    title: 'Magazzini strategici',
    body: 'Ampie metrature a ridosso delle principali arterie autostradali del Nord Italia. Accessi dedicati, ribalte multiple, gestione agile dei flussi in ingresso e uscita.',
    icon: 'warehouse',
  },
  {
    title: 'Spedizioni nazionali e internazionali',
    body: 'Soluzioni end-to-end per distribuzione capillare o consegne dedicate in Italia e in Europa, con tempi cadenzati e tracciatura completa.',
    icon: 'globe',
  },
  {
    title: 'Procedure aggiornate',
    body: 'Processi operativi documentati, continuamente testati e revisionati. Ogni passaggio è tracciato, dalla ricezione merce alla consegna finale.',
    icon: 'shield',
  },
  {
    title: 'Gestione just-in-time',
    body: 'Tempi cadenzati sulle esigenze della tua produzione. Flessibilità su volumi, finestre di consegna e modalità operative.',
    icon: 'clock',
  },
];

const icons: Record<string, string> = {
  warehouse: '<path d="M3 21V9l9-6 9 6v12"></path><path d="M9 21V12h6v9"></path>',
  globe: '<circle cx="12" cy="12" r="10"></circle><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>',
  clock: '<circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>',
};
---

<section class="section-pad bg-byl-white">
  <div class="container-page">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
      <div class="lg:col-span-7">
        <span class="eyebrow">Logistica integrata</span>
        <h2 class="h-section mt-4">
          Magazzini, flussi e spedizioni <span class="text-byl-yellow-dark">senza intoppi</span>.
        </h2>
      </div>
      <div class="lg:col-span-5">
        <p class="lede">
          Ci occupiamo di tutto quello che sta tra la produzione e il
          cliente finale: stoccaggio, picking, preparazione carichi,
          spedizione. Una struttura solida che assorbe picchi, riduce
          errori e libera il tuo team dalla complessità operativa.
        </p>
      </div>
    </div>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-5">
      {
        features.map((f) => (
          <div class="group relative p-8 rounded-xl bg-byl-off border border-byl-stone hover:border-byl-black hover:bg-white hover:shadow-[var(--shadow-hover)] transition-all">
            <div class="w-12 h-12 rounded-lg bg-byl-black text-byl-yellow flex items-center justify-center group-hover:bg-byl-yellow group-hover:text-byl-black transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[f.icon]} />
            </div>
            <h3 class="h-card mt-6">{f.title}</h3>
            <p class="mt-3 text-byl-mute leading-relaxed">{f.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
