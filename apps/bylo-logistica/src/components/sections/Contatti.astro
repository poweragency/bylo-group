---
import { CONTACTS } from '@bylo/ui/index.ts';
---

<section id="contatti" class="section-pad bg-byl-off">
  <div class="container-page">
    <div class="max-w-3xl mx-auto text-center">
      <span class="eyebrow">Parliamone</span>
      <h2 class="h-section mt-4">
        Raccontaci cosa devi <span class="text-byl-yellow-dark">muovere</span>.
      </h2>
      <p class="lede mt-6">
        Scrivici o chiamaci direttamente. Ti rispondiamo entro 24 ore
        lavorative con una proposta operativa concreta.
      </p>
    </div>

    <div class="mt-12 max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
      <a
        href={`tel:${CONTACTS.hq.phone.replace(/\s/g, '')}`}
        class="group flex flex-col p-8 bg-white border border-byl-stone rounded-xl hover:border-byl-black hover:shadow-[var(--shadow-card)] transition-all"
      >
        <span class="text-xs uppercase tracking-[0.18em] font-semibold text-byl-mute">Telefono</span>
        <span class="mt-3 text-xl font-semibold text-byl-black group-hover:text-byl-yellow-dark transition-colors">
          {CONTACTS.hq.phone}
        </span>
        <span class="mt-1 text-sm text-byl-mute">{CONTACTS.hq.hours}</span>
      </a>
      <a
        href={`mailto:${CONTACTS.hq.email}`}
        class="group flex flex-col p-8 bg-white border border-byl-stone rounded-xl hover:border-byl-black hover:shadow-[var(--shadow-card)] transition-all"
      >
        <span class="text-xs uppercase tracking-[0.18em] font-semibold text-byl-mute">Email</span>
        <span class="mt-3 text-xl font-semibold text-byl-black group-hover:text-byl-yellow-dark transition-colors break-all">
          {CONTACTS.hq.email}
        </span>
        <span class="mt-1 text-sm text-byl-mute">Risposta entro 24h lavorative</span>
      </a>
    </div>

    <div class="mt-10 max-w-4xl mx-auto pt-8 border-t border-byl-stone text-center">
      <div class="text-xs uppercase tracking-[0.18em] font-semibold text-byl-mute">
        {CONTACTS.hq.label}
      </div>
      <div class="mt-2 text-byl-black font-medium">
        {CONTACTS.hq.address}
      </div>
    </div>
  </div>
</section>
