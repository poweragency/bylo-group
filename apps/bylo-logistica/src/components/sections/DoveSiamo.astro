---
import { CONTACTS } from '@bylo/ui/index.ts';

const mapsQuery = encodeURIComponent(CONTACTS.hq.address);
const embedSrc = `https://maps.google.com/maps?q=${mapsQuery}&z=15&output=embed`;
const directionsLink = `https://www.google.com/maps/dir/?api=1&destination=${mapsQuery}`;
const openInMaps = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
---

<section id="dove-siamo" class="section-pad bg-byl-white">
  <div class="container-page">
    <div class="max-w-3xl">
      <span class="eyebrow">Dove siamo</span>
      <h2 class="h-section mt-4">
        A un passo dalle principali <span class="text-byl-yellow-dark">arterie autostradali</span>.
      </h2>
      <p class="lede mt-6">
        La nostra sede operativa di Ospiate di Bollate si trova in una
        posizione strategica per la logistica del Nord Italia, con
        accesso rapido alle autostrade A4, A8 e alla tangenziale di Milano.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
      <!-- Info -->
      <aside class="lg:col-span-4 flex flex-col">
        <div class="flex-1 p-8 bg-byl-black text-byl-white rounded-2xl relative overflow-hidden">
          <div
            class="absolute -top-20 -right-20 w-56 h-56 rounded-full blur-3xl opacity-25 pointer-events-none"
            style="background: radial-gradient(circle, var(--color-byl-yellow) 0%, transparent 70%);"
          >
          </div>

          <div class="relative">
            <span class="eyebrow-on-dark">Sede operativa</span>
            <h3 class="h-card mt-3 text-byl-white">
              {CONTACTS.hq.label}
            </h3>

            <address class="not-italic mt-6 text-white/80 leading-relaxed">
              {CONTACTS.hq.address}
            </address>

            <dl class="mt-8 space-y-5 text-sm">
              <div class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-0.5 text-byl-yellow" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                <div>
                  <dt class="text-white/50 text-xs uppercase tracking-wider">Telefono</dt>
                  <dd class="mt-0.5">
                    <a href={`tel:${CONTACTS.hq.phone.replace(/\s/g, '')}`} class="hover:text-byl-yellow transition-colors font-medium">
                      {CONTACTS.hq.phone}
                    </a>
                  </dd>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-0.5 text-byl-yellow" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                <div>
                  <dt class="text-white/50 text-xs uppercase tracking-wider">Email</dt>
                  <dd class="mt-0.5">
                    <a href={`mailto:${CONTACTS.hq.email}`} class="hover:text-byl-yellow transition-colors font-medium break-all">
                      {CONTACTS.hq.email}
                    </a>
                  </dd>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-0.5 text-byl-yellow" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                <div>
                  <dt class="text-white/50 text-xs uppercase tracking-wider">Orari</dt>
                  <dd class="mt-0.5 text-white/80">{CONTACTS.hq.hours}</dd>
                </div>
              </div>
            </dl>

            <a
              href={directionsLink}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary mt-10 w-full"
            >
              Ottieni indicazioni
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"></polygon></svg>
            </a>
          </div>
        </div>
      </aside>

      <!-- Map -->
      <div class="lg:col-span-8">
        <div class="relative h-[420px] md:h-[520px] rounded-2xl overflow-hidden border border-byl-stone bg-byl-stone shadow-[var(--shadow-card)]">
          <iframe
            src={embedSrc}
            title="Mappa della sede BYL Logistica a Ospiate di Bollate"
            class="absolute inset-0 w-full h-full"
            style="border: 0;"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>

          <a
            href={openInMaps}
            target="_blank"
            rel="noopener noreferrer"
            class="absolute bottom-4 right-4 bg-byl-white text-byl-black px-4 py-2.5 rounded-md text-sm font-semibold shadow-lg hover:bg-byl-yellow transition-colors inline-flex items-center gap-2"
          >
            Apri in Google Maps
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
