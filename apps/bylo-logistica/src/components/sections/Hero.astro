---
---

<section class="relative bg-byl-black text-byl-white overflow-hidden">
  <!-- Subtle grid pattern -->
  <div
    class="absolute inset-0 opacity-[0.04] pointer-events-none"
    style="background-image: linear-gradient(to right, #fff 1px, transparent 1px), linear-gradient(to bottom, #fff 1px, transparent 1px); background-size: 80px 80px;"
  >
  </div>

  <!-- Yellow accent blur -->
  <div
    class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full blur-3xl opacity-20 pointer-events-none"
    style="background: radial-gradient(circle, var(--color-byl-yellow) 0%, transparent 70%);"
  >
  </div>

  <div class="container-page relative pt-20 pb-24 md:pt-32 md:pb-36">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <span class="eyebrow-on-dark">
          <span class="inline-block w-2 h-2 rounded-full bg-byl-yellow animate-pulse"></span>
          Trasporti ADR · Logistica integrata
        </span>

        <h1 class="h-display mt-6">
          La logistica che <span class="text-byl-yellow">non si ferma</span> mai.
        </h1>

        <p class="lede mt-6 text-white/70">
          Trasporti nazionali di merci in ADR e servizi logistici integrati.
          Al fianco delle imprese italiane con mezzi certificati, autisti
          qualificati e magazzini strategici sulle principali arterie del Nord.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href="#contatti" class="btn-primary">
            Richiedi un preventivo
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
          <a href="#servizi" class="btn-ghost">Scopri i servizi</a>
        </div>

        <div class="mt-14 grid grid-cols-3 gap-6 max-w-xl">
          <div class="border-l-2 border-byl-yellow pl-4">
            <div class="text-xs uppercase tracking-wider text-white/50">Specializzazione</div>
            <div class="mt-1 font-semibold text-white">Merci ADR</div>
          </div>
          <div class="border-l-2 border-byl-yellow pl-4">
            <div class="text-xs uppercase tracking-wider text-white/50">Copertura</div>
            <div class="mt-1 font-semibold text-white">Nazionale</div>
          </div>
          <div class="border-l-2 border-byl-yellow pl-4">
            <div class="text-xs uppercase tracking-wider text-white/50">Tempi</div>
            <div class="mt-1 font-semibold text-white">Just-in-time</div>
          </div>
        </div>
      </div>

      <!-- Right: visual -->
      <div class="lg:col-span-5 relative">
        <div class="relative aspect-[4/5] rounded-2xl overflow-hidden bg-gradient-to-br from-byl-graphite to-byl-black border border-white/5">
          <!-- Animated truck-on-road scene -->
          <div class="absolute inset-0">
            <svg viewBox="0 0 400 500" class="w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
              <defs>
                <linearGradient id="heroSky" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0" stop-color="#0a0a0a" />
                  <stop offset="1" stop-color="#222" />
                </linearGradient>
                <linearGradient id="heroRoad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0" stop-color="#1c1c1c" />
                  <stop offset="1" stop-color="#0a0a0a" />
                </linearGradient>
              </defs>

              <!-- Sky -->
              <rect x="0" y="0" width="400" height="300" fill="url(#heroSky)" />

              <!-- Horizon glow -->
              <rect x="0" y="295" width="400" height="8" fill="var(--color-byl-yellow)" opacity="0.08" />
              <rect x="0" y="299" width="400" height="2" fill="var(--color-byl-yellow)" opacity="0.3" />

              <!-- Distant city silhouette (slow parallax) -->
              <g opacity="0.45">
                <g>
                  <rect x="20" y="270" width="40" height="30" fill="#1a1a1a" />
                  <rect x="70" y="255" width="30" height="45" fill="#1a1a1a" />
                  <rect x="110" y="265" width="50" height="35" fill="#1a1a1a" />
                  <rect x="180" y="245" width="35" height="55" fill="#1a1a1a" />
                  <rect x="225" y="260" width="45" height="40" fill="#1a1a1a" />
                  <rect x="290" y="255" width="40" height="45" fill="#1a1a1a" />
                  <rect x="340" y="270" width="50" height="30" fill="#1a1a1a" />
                  <rect x="420" y="270" width="40" height="30" fill="#1a1a1a" />
                  <rect x="470" y="255" width="30" height="45" fill="#1a1a1a" />
                  <rect x="510" y="265" width="50" height="35" fill="#1a1a1a" />
                  <rect x="580" y="245" width="35" height="55" fill="#1a1a1a" />
                  <rect x="625" y="260" width="45" height="40" fill="#1a1a1a" />
                  <rect x="690" y="255" width="40" height="45" fill="#1a1a1a" />
                  <rect x="740" y="270" width="50" height="30" fill="#1a1a1a" />
                </g>
                <animateTransform attributeName="transform" type="translate" from="0 0" to="-400 0" dur="9s" repeatCount="indefinite" />
              </g>

              <!-- Mid-distance poles (medium parallax) -->
              <g>
                <g>
                  <rect x="40" y="248" width="2" height="52" fill="#3f3f3f" />
                  <rect x="180" y="248" width="2" height="52" fill="#3f3f3f" />
                  <rect x="320" y="248" width="2" height="52" fill="#3f3f3f" />
                  <rect x="460" y="248" width="2" height="52" fill="#3f3f3f" />
                  <rect x="600" y="248" width="2" height="52" fill="#3f3f3f" />
                </g>
                <animateTransform attributeName="transform" type="translate" from="0 0" to="-280 0" dur="2.5s" repeatCount="indefinite" />
              </g>

              <!-- Road -->
              <rect x="0" y="300" width="400" height="200" fill="url(#heroRoad)" />
              <rect x="0" y="303" width="400" height="1" fill="#fff" opacity="0.12" />

              <!-- Road dashes (foreground, fast) -->
              <g>
                <g>
                  <rect x="-30" y="448" width="55" height="6" rx="2" fill="var(--color-byl-yellow)" />
                  <rect x="90" y="448" width="55" height="6" rx="2" fill="var(--color-byl-yellow)" />
                  <rect x="210" y="448" width="55" height="6" rx="2" fill="var(--color-byl-yellow)" />
                  <rect x="330" y="448" width="55" height="6" rx="2" fill="var(--color-byl-yellow)" />
                  <rect x="450" y="448" width="55" height="6" rx="2" fill="var(--color-byl-yellow)" />
                </g>
                <animateTransform attributeName="transform" type="translate" from="0 0" to="-120 0" dur="0.5s" repeatCount="indefinite" />
              </g>

              <!-- Wind/speed streaks beside the truck -->
              <g opacity="0.55">
                <line y1="338" y2="338" stroke="var(--color-byl-yellow)" stroke-width="2" stroke-linecap="round">
                  <animate attributeName="x1" values="420;-60" dur="0.6s" repeatCount="indefinite" />
                  <animate attributeName="x2" values="470;-10" dur="0.6s" repeatCount="indefinite" />
                  <animate attributeName="opacity" values="0;0.7;0" dur="0.6s" repeatCount="indefinite" />
                </line>
                <line y1="368" y2="368" stroke="#fff" stroke-width="1.5" stroke-linecap="round">
                  <animate attributeName="x1" values="420;-60" dur="0.7s" repeatCount="indefinite" begin="0.2s" />
                  <animate attributeName="x2" values="470;-10" dur="0.7s" repeatCount="indefinite" begin="0.2s" />
                  <animate attributeName="opacity" values="0;0.5;0" dur="0.7s" repeatCount="indefinite" begin="0.2s" />
                </line>
                <line y1="398" y2="398" stroke="var(--color-byl-yellow)" stroke-width="2" stroke-linecap="round">
                  <animate attributeName="x1" values="420;-60" dur="0.55s" repeatCount="indefinite" begin="0.35s" />
                  <animate attributeName="x2" values="470;-10" dur="0.55s" repeatCount="indefinite" begin="0.35s" />
                  <animate attributeName="opacity" values="0;0.6;0" dur="0.55s" repeatCount="indefinite" begin="0.35s" />
                </line>
              </g>

              <!-- ===== TRUCK (realistic box truck with BYL logo) ===== -->
              <g>
                <animateTransform attributeName="transform" type="translate" values="0 0; 0 -1; 0 0; 0 -0.5; 0 0" dur="0.4s" repeatCount="indefinite" />

                <!-- Ground shadow -->
                <ellipse cx="200" cy="423" rx="140" ry="6" fill="#000" opacity="0.55" />

                <!-- ===== CARGO BOX ===== -->
                <rect x="65" y="263" width="180" height="125" rx="3" fill="#f8f8f8" />
                <rect x="65" y="263" width="180" height="125" rx="3" fill="none" stroke="#cccccc" stroke-width="1" />
                <!-- Top yellow accent strip -->
                <rect x="65" y="263" width="180" height="7" fill="var(--color-byl-yellow)" />
                <rect x="65" y="270" width="180" height="2" fill="#000" opacity="0.2" />
                <!-- Subtle panel division lines -->
                <line x1="125" y1="275" x2="125" y2="382" stroke="#dddddd" stroke-width="0.8" />
                <line x1="185" y1="275" x2="185" y2="382" stroke="#dddddd" stroke-width="0.8" />
                <!-- Bottom shading strip -->
                <rect x="65" y="380" width="180" height="8" fill="#000" opacity="0.15" />
                <!-- Rear door handle (cab side) -->
                <rect x="238" y="328" width="4" height="22" rx="1" fill="#999" />
                <rect x="238" y="328" width="4" height="2" fill="#555" />

                <!-- ===== BYL TRANSPORTS & COMMERCE LOGO ===== -->
                <image href="/logo.png" x="75" y="293" width="160" height="58" preserveAspectRatio="xMidYMid meet" />

                <!-- ===== CAB ===== -->
                <!-- Dark gap between box and cab -->
                <rect x="245" y="305" width="4" height="83" fill="#0a0a0a" />
                <!-- Cab body with sloped windshield -->
                <path d="M 249 388 L 249 322 Q 249 305 264 305 L 302 305 L 322 322 L 324 388 Z" fill="var(--color-byl-yellow)" />
                <!-- Roof highlight -->
                <path d="M 264 305 L 302 305 L 303 311 L 263 311 Z" fill="#ffffff" opacity="0.25" />
                <!-- Cab bottom shading -->
                <path d="M 249 378 L 324 378 L 324 388 L 249 388 Z" fill="#000" opacity="0.18" />
                <!-- Windshield -->
                <path d="M 256 320 L 263 312 L 297 312 L 299 320 L 299 343 L 256 343 Z" fill="#0a0a0a" />
                <!-- Windshield reflections -->
                <path d="M 263 314 L 285 314 L 281 320 L 261 320 Z" fill="#ffffff" opacity="0.2" />
                <path d="M 268 323 L 282 323 L 280 332 L 270 332 Z" fill="#ffffff" opacity="0.08" />
                <!-- A-pillar -->
                <rect x="298" y="320" width="2" height="23" fill="var(--color-byl-yellow)" />
                <!-- Side window (door) -->
                <path d="M 302 322 L 320 322 L 322 343 L 302 343 Z" fill="#0a0a0a" />
                <path d="M 304 324 L 314 324 L 313 330 L 304 330 Z" fill="#ffffff" opacity="0.12" />
                <!-- Door panel line -->
                <line x1="299" y1="345" x2="299" y2="378" stroke="#0a0a0a" stroke-width="0.8" opacity="0.4" />
                <!-- Door handle -->
                <rect x="308" y="358" width="9" height="3" rx="1" fill="#0a0a0a" opacity="0.7" />
                <!-- Side mirror -->
                <line x1="320" y1="326" x2="326" y2="320" stroke="#0a0a0a" stroke-width="1.5" />
                <rect x="324" y="313" width="7" height="13" rx="1.5" fill="#0a0a0a" />
                <rect x="325" y="314" width="5" height="10" rx="0.5" fill="#bbbbbb" opacity="0.45" />
                <!-- Front bumper -->
                <rect x="320" y="378" width="8" height="14" rx="1" fill="#1a1a1a" />
                <rect x="320" y="378" width="8" height="2" fill="var(--color-byl-yellow)" />
                <!-- Headlight -->
                <rect x="320" y="358" width="6" height="11" rx="1.5" fill="#f8f8f8">
                  <animate attributeName="opacity" values="0.75;1;0.75" dur="1.6s" repeatCount="indefinite" />
                </rect>
                <rect x="321" y="361" width="4" height="3" fill="#ffeb99" opacity="0.9" />
                <!-- Grille -->
                <line x1="320" y1="372" x2="325" y2="372" stroke="#0a0a0a" stroke-width="0.6" />
                <line x1="320" y1="374" x2="325" y2="374" stroke="#0a0a0a" stroke-width="0.6" />
                <!-- Side step -->
                <rect x="299" y="388" width="22" height="3" fill="#1a1a1a" />

                <!-- ===== CHASSIS FRAME ===== -->
                <rect x="78" y="388" width="245" height="3" fill="#1a1a1a" />
                <rect x="78" y="391" width="245" height="2" fill="#000" opacity="0.6" />

                <!-- ===== WHEEL ARCHES ===== -->
                <ellipse cx="110" cy="395" rx="22" ry="10" fill="#050505" />
                <ellipse cx="170" cy="395" rx="22" ry="10" fill="#050505" />
                <ellipse cx="278" cy="395" rx="22" ry="10" fill="#050505" />

                <!-- ===== WHEELS ===== -->
                <g>
                  <animateTransform attributeName="transform" type="rotate" from="0 110 405" to="360 110 405" dur="0.45s" repeatCount="indefinite" />
                  <circle cx="110" cy="405" r="16" fill="#1a1a1a" stroke="#000" stroke-width="1" />
                  <circle cx="110" cy="405" r="11" fill="#2a2a2a" />
                  <circle cx="110" cy="405" r="5" fill="#555" />
                  <circle cx="110" cy="405" r="2" fill="#888" />
                  <line x1="110" y1="394" x2="110" y2="416" stroke="#666" stroke-width="1.5" />
                  <line x1="99" y1="405" x2="121" y2="405" stroke="#666" stroke-width="1.5" />
                  <line x1="102" y1="397" x2="118" y2="413" stroke="#555" stroke-width="1" />
                  <line x1="118" y1="397" x2="102" y2="413" stroke="#555" stroke-width="1" />
                </g>
                <g>
                  <animateTransform attributeName="transform" type="rotate" from="0 170 405" to="360 170 405" dur="0.45s" repeatCount="indefinite" />
                  <circle cx="170" cy="405" r="16" fill="#1a1a1a" stroke="#000" stroke-width="1" />
                  <circle cx="170" cy="405" r="11" fill="#2a2a2a" />
                  <circle cx="170" cy="405" r="5" fill="#555" />
                  <circle cx="170" cy="405" r="2" fill="#888" />
                  <line x1="170" y1="394" x2="170" y2="416" stroke="#666" stroke-width="1.5" />
                  <line x1="159" y1="405" x2="181" y2="405" stroke="#666" stroke-width="1.5" />
                  <line x1="162" y1="397" x2="178" y2="413" stroke="#555" stroke-width="1" />
                  <line x1="178" y1="397" x2="162" y2="413" stroke="#555" stroke-width="1" />
                </g>
                <g>
                  <animateTransform attributeName="transform" type="rotate" from="0 278 405" to="360 278 405" dur="0.45s" repeatCount="indefinite" />
                  <circle cx="278" cy="405" r="16" fill="#1a1a1a" stroke="#000" stroke-width="1" />
                  <circle cx="278" cy="405" r="11" fill="#2a2a2a" />
                  <circle cx="278" cy="405" r="5" fill="#555" />
                  <circle cx="278" cy="405" r="2" fill="#888" />
                  <line x1="278" y1="394" x2="278" y2="416" stroke="#666" stroke-width="1.5" />
                  <line x1="267" y1="405" x2="289" y2="405" stroke="#666" stroke-width="1.5" />
                  <line x1="270" y1="397" x2="286" y2="413" stroke="#555" stroke-width="1" />
                  <line x1="286" y1="397" x2="270" y2="413" stroke="#555" stroke-width="1" />
                </g>
              </g>
            </svg>
          </div>
          <!-- Corner badge -->
          <div class="absolute top-6 left-6 bg-byl-yellow text-byl-black px-3 py-1.5 text-xs font-bold uppercase tracking-wider rounded-sm z-10">
            ADR Certified
          </div>
        </div>

        <!-- Floating card -->
        <div class="hidden md:block absolute -bottom-6 -left-6 bg-byl-white text-byl-black p-5 rounded-xl shadow-2xl max-w-[240px]">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-byl-yellow flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            </div>
            <div>
              <div class="font-semibold text-sm">Sicurezza certificata</div>
              <div class="text-xs text-byl-mute">Classi 2, 3, 4, 5, 6, 8, 9</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2 text-white/40 text-xs">
    <span>Scopri di più</span>
    <div class="w-[1px] h-12 bg-gradient-to-b from-white/40 to-transparent"></div>
  </div>
</section>
