---
const currentLocale = (Astro.currentLocale ?? 'it') as 'it' | 'en';
const isEN = currentLocale === 'en';

const t = {
  it: {
    servizi: 'Servizi',
    settori: 'Settori',
    tratte: 'Tratte',
    contatti: 'Contatti',
    cta: 'Richiedi preventivo',
    home: 'BYLO Transport — home',
    menuLabel: 'Apri menu',
    switchLabel: 'English',
  },
  en: {
    servizi: 'Services',
    settori: 'Sectors',
    tratte: 'Routes',
    contatti: 'Contact',
    cta: 'Request a quote',
    home: 'BYLO Transport — home',
    menuLabel: 'Open menu',
    switchLabel: 'Italiano',
  },
}[currentLocale];

const base = isEN ? '/en' : '';
// Nei link verso le sezioni listing, la URL e' /servizi/ in IT, /en/services/ in EN.
const sectionPath = isEN ? {
  servizi: '/en/services/',
  settori: '/en/sectors/',
  tratte: '/en/routes/',
} : {
  servizi: '/servizi/',
  settori: '/settori/',
  tratte: '/tratte/',
};
const contattiAnchor = `${base}/#contatti`;

const nav = [
  { href: sectionPath.servizi, label: t.servizi },
  { href: sectionPath.settori, label: t.settori },
  { href: sectionPath.tratte, label: t.tratte },
  { href: contattiAnchor, label: t.contatti },
];

const switchHref = isEN
  ? Astro.url.pathname.replace(/^\/en(\/|$)/, '/')
  : `/en${Astro.url.pathname === '/' ? '' : Astro.url.pathname}`;
---

<header
  class="sticky top-0 z-50 bg-byl-white border-b border-byl-stone text-byl-black"
>
  <div class="container-page flex items-center justify-between h-16 md:h-20">
    <a href={base || '/'} class="flex items-baseline gap-1.5" aria-label={t.home}>
      <span class="font-display font-black text-2xl md:text-3xl tracking-tight text-byl-black">
        BYLO
      </span>
      <span class="font-display font-medium text-base md:text-lg tracking-[0.22em] uppercase text-byl-mute">
        Transport
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-byl-black hover:text-byl-yellow-dark transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={switchHref}
        class="text-xs uppercase tracking-wider font-medium text-byl-mute hover:text-byl-black transition-colors"
        aria-label={t.switchLabel}
      >
        {isEN ? 'IT' : 'EN'}
      </a>
      <a href={contattiAnchor} class="btn-primary hidden sm:inline-flex text-sm">
        {t.cta}
      </a>
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-byl-black"
        aria-label={t.menuLabel}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-byl-stone bg-byl-white">
    <nav class="container-page py-4 flex flex-col gap-1">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="py-3 text-base font-medium text-byl-black hover:text-byl-yellow-dark"
          >
            {item.label}
          </a>
        ))
      }
      <a href={switchHref} class="py-3 text-base font-medium text-byl-mute hover:text-byl-black">
        {t.switchLabel}
      </a>
      <a href={contattiAnchor} class="btn-primary mt-3 text-sm w-full">
        {t.cta}
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
