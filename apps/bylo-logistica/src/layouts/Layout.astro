---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { Seo, Hreflang, SchemaOrg } from '@bylo/ui/seo/index.ts';
import {
  BRAND,
  GROUP,
  LEGAL_TRANSPORT,
  CONTACTS,
} from '@bylo/ui/index.ts';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const currentLocale = (Astro.currentLocale ?? 'it') as 'it' | 'en';
const isEN = currentLocale === 'en';
const ogLocale = isEN ? 'en_US' : 'it_IT';
const htmlLang = isEN ? 'en' : 'it';

const defaultTitle = isEN
  ? 'BYLO Transport — National ADR Transport & Integrated Logistics'
  : 'BYLO Transport — Trasporti ADR e Logistica Integrata';
const defaultDescription = isEN
  ? 'National ADR cargo transport and integrated logistics services. Reliability, safety and nationwide coverage for Italian companies.'
  : 'Trasporti nazionali di merci in ADR e servizi logistici integrati. Affidabilità, sicurezza e copertura nazionale al servizio delle imprese italiane.';

const {
  title = defaultTitle,
  description = defaultDescription,
  ogImage,
  noindex,
} = Astro.props;

const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? '';
const path = Astro.url.pathname;

function altUrl(target: 'it' | 'en'): string {
  if (target === 'it') {
    const stripped = path.replace(/^\/en(\/|$)/, '/');
    return `${siteOrigin}${stripped}`;
  }
  if (path.startsWith('/en/') || path === '/en') {
    return `${siteOrigin}${path}`;
  }
  return `${siteOrigin}/en${path === '/' ? '' : path}`;
}

const alternates = [
  { hreflang: 'it', href: altUrl('it') },
  { hreflang: 'en', href: altUrl('en') },
];

// LocalBusiness JSON-LD per la sede di Bollate
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${siteOrigin}/#localbusiness`,
  name: BRAND.name,
  legalName: LEGAL_TRANSPORT.name,
  url: siteOrigin,
  logo: `${siteOrigin}/logo.png`,
  vatID: LEGAL_TRANSPORT.vat,
  parentOrganization: {
    '@type': 'Organization',
    name: GROUP.name,
    url: GROUP.website,
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via Ghisalba 7',
    postalCode: '20021',
    addressLocality: 'Ospiate di Bollate',
    addressRegion: 'MI',
    addressCountry: 'IT',
  },
  telephone: CONTACTS.hq.phone,
  email: CONTACTS.hq.email,
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '12:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '14:00',
      closes: '18:00',
    },
  ],
  areaServed: [
    { '@type': 'Country', name: 'Italy' },
    { '@type': 'Country', name: 'Europe' },
  ],
  description: isEN
    ? 'BYLO Transport runs ADR transport for dangerous goods (classes 2, 3, 4.1, 4.2, 5.1, 5.2, 6.1, 8 and 9) and integrated logistics on national and international routes from Ospiate di Bollate (Milan).'
    : 'BYLO Transport esegue trasporti ADR di merci pericolose (classi 2, 3, 4.1, 4.2, 5.1, 5.2, 6.1, 8 e 9) e logistica integrata su tratte nazionali e internazionali, dalla sede di Ospiate di Bollate (MI).',
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <Seo
      title={title}
      description={description}
      ogImage={ogImage}
      locale={ogLocale}
      noindex={noindex}
      siteName={BRAND.name}
    />
    <Hreflang alternates={alternates} xDefault={altUrl('it')} />
    <SchemaOrg data={localBusinessSchema} />
  </head>
  <body class="bg-byl-white text-byl-black antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
