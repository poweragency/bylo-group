---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import {
  GROUP,
  LEGAL_TRANSPORT,
  LEGAL_TOMMY,
  CONTACTS,
  CONTACTS_RACING,
  CONTACTS_GROUP,
} from '@bylo/ui/index.ts';

const title = 'BYLO Group — Transport, logistics and automotive';
const description =
  'BYLO Group is the holding company behind BYLO Transport (ADR transport and integrated logistics) and Tommy By (auto repair and body shop). Services for Italian businesses.';

const numbers = [
  { value: '25+', label: 'Years of experience' },
  { value: '3', label: 'Operating sites' },
  { value: '30+', label: 'Vehicles in the fleet' },
  { value: 'All', label: 'Car brands serviced' },
];

const values = [
  {
    title: 'Safety & quality',
    body:
      'ADR-certified transport, authorized auto repair, body shop with oven painting. High standards, checks at every step.',
  },
  {
    title: 'Italian roots',
    body:
      'Family-run companies based in Lombardy, serving Italian clients who speak our same language.',
  },
  {
    title: 'Multi-brand expertise',
    body:
      'Authorized workshop for all car brands, transport for every sector. One team, thousands of problems already solved.',
  },
  {
    title: 'Transparency & reliability',
    body:
      'Clear quotes, on-time delivery, direct communication. We work with companies that want a single point of contact, not a call center.',
  },
];

const pillars = [
  {
    href: 'https://transport.bylogroup.it',
    eyebrow: 'BYLO TRANSPORT S.R.L.',
    title: 'BYLO Transport',
    tagline: 'ADR transport & integrated logistics',
    bullets: [
      'National transport of dangerous goods (classes 2, 3, 4, 5, 6, 8, 9)',
      'Integrated logistics, warehousing and distribution',
      'Operational HQ and warehouse in Ospiate di Bollate (MI)',
      'Italian Carriers Registry MI/8906297N',
    ],
    cta: 'Discover BYLO Transport',
  },
  {
    href: 'https://tommy.bylogroup.it',
    eyebrow: 'TOMMY BY S.R.L.',
    title: 'Tommy By',
    tagline: 'Multi-brand auto repair & body shop',
    bullets: [
      'Authorized workshop for all car brands',
      'Body shop with water-based oven painting',
      'Selected used car sales, inspected and documented',
      'Two locations in Rho (MI): repair shop and body shop',
    ],
    cta: 'Discover Tommy By',
  },
];

const locations = [
  {
    label: 'BYLO Transport — Operational HQ',
    address: CONTACTS.hq.address,
    phone: CONTACTS.hq.phone,
  },
  {
    label: 'Tommy By — Repair shop',
    address: CONTACTS_RACING.officina.address,
    phone: CONTACTS_RACING.officina.phone,
  },
  {
    label: 'Tommy By — Body shop',
    address: CONTACTS_RACING.carrozzeria.address,
    phone: CONTACTS_RACING.carrozzeria.phone,
  },
];
---

<Layout title={title} description={description}>
  <Header />
  <main>
    <!-- HERO -->
    <section class="section-pad bg-byl-black text-byl-white relative overflow-hidden">
      <div
        class="absolute inset-0 opacity-[0.04] pointer-events-none"
        style="background-image: linear-gradient(to right, #fff 1px, transparent 1px), linear-gradient(to bottom, #fff 1px, transparent 1px); background-size: 80px 80px;"
      />
      <div class="container-page relative">
        <div class="max-w-3xl">
          <span class="eyebrow text-byl-yellow">Holding · BYLO Group</span>
          <h1 class="h-display mt-6">
            Transport, logistics and automotive
            <span class="text-byl-yellow">under one roof.</span>
          </h1>
          <p class="lede mt-6 text-white/70">
            BYLO Group brings together two complementary companies: BYLO
            Transport for ADR transport and integrated logistics, Tommy By
            for multi-brand auto repair and body shop. Together we cover the
            full lifecycle of a vehicle, from production to after-sales.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a href="#companies" class="btn-primary">
              Discover the group's companies
            </a>
            <a href="#contact" class="btn-ghost">
              Corporate contact
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="section-pad bg-byl-white">
      <div class="container-page">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
          <div class="lg:col-span-5">
            <span class="eyebrow text-byl-yellow-dark">About us</span>
            <h2 class="h-section mt-4">
              Two specializations, <span class="text-byl-yellow-dark">one shared vision.</span>
            </h2>
          </div>
          <div class="lg:col-span-7 space-y-5 text-byl-black/80 leading-relaxed">
            <p>
              {GROUP.name} is the holding company behind two long-standing
              Italian businesses: BYLO Transport, active in dangerous goods
              transport and integrated logistics, and Tommy By, a
              multi-brand auto repair and body shop based in Rho (MI).
            </p>
            <p>
              The two companies operate independently but team up whenever
              clients need solutions that bridge both worlds: from corporate
              fleet maintenance to single-vehicle care.
            </p>
            <p>
              We are family-run businesses. No call centers, no long supply
              chains: the person picking up the phone is the person solving
              your problem.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NUMBERS -->
    <section class="bg-byl-off py-16 md:py-20 border-y border-byl-stone">
      <div class="container-page">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
          {numbers.map((n) => (
            <div class="text-center md:text-left">
              <div class="font-display font-bold text-4xl md:text-5xl text-byl-black">
                {n.value}
              </div>
              <div class="mt-2 text-sm text-byl-mute uppercase tracking-wider">
                {n.label}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- COMPANIES -->
    <section id="companies" class="section-pad bg-byl-white">
      <div class="container-page">
        <div class="max-w-3xl">
          <span class="eyebrow text-byl-yellow-dark">Group companies</span>
          <h2 class="h-section mt-4">
            Two companies, one <span class="text-byl-yellow-dark">single standard</span>.
          </h2>
          <p class="lede mt-6 text-byl-mute">
            Each company in the group has its own specialization and dedicated site. Pick the one you need.
          </p>
        </div>

        <div class="mt-14 grid grid-cols-1 lg:grid-cols-2 gap-8">
          {pillars.map((p) => (
            <a
              href={p.href}
              class="group block p-8 md:p-10 rounded-2xl border border-byl-stone bg-byl-white hover:border-byl-black hover:shadow-[var(--shadow-hover)] transition-all"
            >
              <span class="text-xs font-semibold uppercase tracking-[0.18em] text-byl-mute">
                {p.eyebrow}
              </span>
              <h3 class="font-display font-bold text-3xl md:text-4xl mt-3 text-byl-black">
                {p.title}
              </h3>
              <p class="mt-2 text-byl-yellow-dark font-medium">{p.tagline}</p>

              <ul class="mt-6 space-y-3">
                {p.bullets.map((b) => (
                  <li class="flex gap-3 text-sm text-byl-black/80 leading-relaxed">
                    <span class="flex-shrink-0 w-1.5 h-1.5 mt-2 rounded-full bg-byl-yellow-dark"></span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-8 inline-flex items-center gap-2 text-byl-black font-semibold group-hover:text-byl-yellow-dark transition-colors">
                {p.cta}
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- VALUES -->
    <section class="section-pad bg-byl-black text-byl-white">
      <div class="container-page">
        <div class="max-w-3xl">
          <span class="eyebrow text-byl-yellow">Our values</span>
          <h2 class="h-section mt-4 text-byl-white">
            Four pillars, <span class="text-byl-yellow">one way of working</span>.
          </h2>
        </div>

        <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-6">
          {values.map((v, i) => (
            <div class="p-8 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/[0.07] transition-colors">
              <div class="flex items-start gap-5">
                <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-byl-yellow flex items-center justify-center font-display font-bold text-byl-black text-lg">
                  {String(i + 1).padStart(2, '0')}
                </div>
                <div>
                  <h3 class="font-display font-bold text-xl text-byl-white">{v.title}</h3>
                  <p class="mt-2 text-white/70 leading-relaxed text-sm">{v.body}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- LOCATIONS -->
    <section class="section-pad bg-byl-off">
      <div class="container-page">
        <div class="max-w-3xl">
          <span class="eyebrow text-byl-yellow-dark">Locations</span>
          <h2 class="h-section mt-4">
            Three operational sites <span class="text-byl-yellow-dark">in Lombardy</span>.
          </h2>
        </div>

        <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
          {locations.map((loc) => (
            <div class="p-6 rounded-2xl bg-white border border-byl-stone">
              <h3 class="font-display font-bold text-base text-byl-black">
                {loc.label}
              </h3>
              <p class="mt-3 text-sm text-byl-mute leading-relaxed">
                {loc.address}
              </p>
              <a
                href={`tel:${loc.phone.replace(/\s/g, '')}`}
                class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-byl-black hover:text-byl-yellow-dark transition-colors"
              >
                {loc.phone}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="section-pad bg-byl-white">
      <div class="container-page">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
          <div class="lg:col-span-5">
            <span class="eyebrow text-byl-yellow-dark">Corporate contact</span>
            <h2 class="h-section mt-4">
              Talk to the <span class="text-byl-yellow-dark">group</span>, not a call center.
            </h2>
            <p class="lede mt-6 text-byl-mute">
              For corporate requests, suppliers, partnerships or press, write to the group. For specific services (transport or repair) please use the dedicated company sites.
            </p>
          </div>
          <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a
              href={`mailto:${CONTACTS_GROUP.email}`}
              class="p-6 rounded-2xl border border-byl-stone bg-byl-off hover:border-byl-black transition-colors"
            >
              <span class="text-xs uppercase tracking-wider font-semibold text-byl-mute">
                Group email
              </span>
              <p class="mt-2 font-display font-bold text-byl-black break-all">
                {CONTACTS_GROUP.email}
              </p>
            </a>
            <a
              href={`mailto:${CONTACTS_GROUP.press}`}
              class="p-6 rounded-2xl border border-byl-stone bg-byl-off hover:border-byl-black transition-colors"
            >
              <span class="text-xs uppercase tracking-wider font-semibold text-byl-mute">
                Press
              </span>
              <p class="mt-2 font-display font-bold text-byl-black break-all">
                {CONTACTS_GROUP.press}
              </p>
            </a>
            <a
              href={`tel:${CONTACTS_GROUP.phone.replace(/\s/g, '')}`}
              class="sm:col-span-2 p-6 rounded-2xl border border-byl-stone bg-byl-off hover:border-byl-black transition-colors"
            >
              <span class="text-xs uppercase tracking-wider font-semibold text-byl-mute">
                Phone
              </span>
              <p class="mt-2 font-display font-bold text-byl-black">
                {CONTACTS_GROUP.phone}
              </p>
              <p class="mt-1 text-sm text-byl-mute">
                BYLO Transport main line — answers for the group
              </p>
            </a>
          </div>
        </div>

        <div class="mt-16 p-8 rounded-2xl bg-byl-black text-white text-center">
          <p class="text-white/80">
            <strong class="text-byl-yellow">{LEGAL_TRANSPORT.name}</strong>
            · VAT {LEGAL_TRANSPORT.vat}
            <span class="mx-3 text-white/30">·</span>
            <strong class="text-byl-yellow">{LEGAL_TOMMY.name}</strong>
            · VAT {LEGAL_TOMMY.vat}
          </p>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="section-pad bg-byl-yellow">
      <div class="container-page text-center">
        <h2 class="h-section text-byl-black">
          Ready to work with the BYLO group?
        </h2>
        <p class="lede mt-4 text-byl-black/70 max-w-2xl mx-auto">
          Pick the right company for your need: transport and logistics with BYLO Transport, auto repair and body shop with Tommy By.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://transport.bylogroup.it" class="btn-primary bg-byl-black text-byl-yellow shadow-[0_4px_0_0_rgba(0,0,0,0.4)] hover:bg-byl-graphite">
            Visit BYLO Transport
          </a>
          <a href="https://tommy.bylogroup.it" class="btn-outline">
            Visit Tommy By
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
